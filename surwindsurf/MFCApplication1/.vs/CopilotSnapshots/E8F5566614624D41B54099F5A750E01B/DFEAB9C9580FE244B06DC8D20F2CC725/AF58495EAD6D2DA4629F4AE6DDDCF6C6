// 232串口处理函数
void CMFCApplication1Dlg::OnBnClickedButtonOpen232()
{
	CButton* pBtn = (CButton*)GetDlgItem(IDC_BUTTON_OPEN232);
	if (!pBtn) return;
	
	if (!m_serial232.IsOpen())
	{
		// 获取串口参数
		CComboBox* pCombo = (CComboBox*)GetDlgItem(IDC_COMBO_COM232);
		int nPort = pCombo->GetCurSel() + 1;
		
		pCombo = (CComboBox*)GetDlgItem(IDC_COMBO_BAUDRATE232);
		CString strBaud;
		pCombo->GetLBText(pCombo->GetCurSel(), strBaud);
		int nBaudRate = _ttoi(strBaud);
		
		pCombo = (CComboBox*)GetDlgItem(IDC_COMBO_DATABITS232);
		CString strDataBits;
		pCombo->GetLBText(pCombo->GetCurSel(), strDataBits);
		int nDataBits = _ttoi(strDataBits);
		
		pCombo = (CComboBox*)GetDlgItem(IDC_COMBO_STOPBITS232);
		int nStopBits = pCombo->GetCurSel();
		
		pCombo = (CComboBox*)GetDlgItem(IDC_COMBO_PARITY232);
		int nParity = pCombo->GetCurSel();
		
		// 打开串口
		if (m_serial232.Open(nPort, nBaudRate, nDataBits, nStopBits, nParity))
		{
			pBtn->SetWindowText(_T("关闭"));
			CString strMsg;
			strMsg.Format(_T("232串口 COM%d 打开成功"), nPort);
			CLogManager::GetInstance().AddLog(_T("232串口"), LOG_INFO, strMsg);
		}
		else
		{
			MessageBox(_T("打开232串口失败！"), _T("错误"), MB_OK | MB_ICONERROR);
			CLogManager::GetInstance().AddLog(_T("232串口"), LOG_ERROR, _T("打开232串口失败"));
		}
	}
	else
	{
		// 关闭串口
		m_serial232.Close();
		pBtn->SetWindowText(_T("打开"));
		CLogManager::GetInstance().AddLog(_T("232串口"), LOG_INFO, _T("232串口已关闭"));
	}
}

void CMFCApplication1Dlg::OnBnClickedButtonSend232()
{
	if (!m_serial232.IsOpen())
	{
		MessageBox(_T("请先打开232串口！"), _T("提示"), MB_OK | MB_ICONINFORMATION);
		return;
	}
	
	CString strSend;
	GetDlgItemText(IDC_EDIT_SEND232, strSend);
	
	if (strSend.IsEmpty())
	{
		return;
	}
	
	// 检查是否十六进制模式
	CButton* pCheck = (CButton*)GetDlgItem(IDC_CHECK_HEX232);
	BOOL bHex = pCheck ? pCheck->GetCheck() : FALSE;
	
	CStringA strSendA(strSend);
	// 使用新的SendData方法，自动添加终止符 0x0A 0x0D 0x0A 0x0D
	if (m_serial232.SendData(strSendA.GetString(), strSendA.GetLength(), TRUE))
	{
		CLogManager::GetInstance().AddLog(_T("232串口"), LOG_INFO, _T("发送数据成功"));
	}
	else
	{
		CLogManager::GetInstance().AddLog(_T("232串口"), LOG_ERROR, _T("发送数据失败"));
	}
}

