// 机械臂处理函数
void CMFCApplication1Dlg::OnBnClickedButtonConnectRobot()
{
	CButton* pBtn = (CButton*)GetDlgItem(IDC_BUTTON_CONNECT_ROBOT);
	if (!pBtn) return;
	
	if (!m_robotArm.IsConnected())
	{
		CComboBox* pCombo = (CComboBox*)GetDlgItem(IDC_COMBO_COM_ROBOT);
		int nPort = pCombo->GetCurSel() + 1;
		
		pCombo = (CComboBox*)GetDlgItem(IDC_COMBO_BAUDRATE_ROBOT);
		CString strBaud;
		pCombo->GetLBText(pCombo->GetCurSel(), strBaud);
		int nBaudRate = _ttoi(strBaud);
		
		if (m_robotArm.Connect(nPort, nBaudRate))
		{
			pBtn->SetWindowText(_T("断开"));
			CString strMsg;
			strMsg.Format(_T("机械臂连接成功 COM%d"), nPort);
			CLogManager::GetInstance().AddLog(_T("机械臂"), LOG_INFO, strMsg);
		}
		else
		{
			MessageBox(_T("连接机械臂失败！"), _T("错误"), MB_OK | MB_ICONERROR);
			CLogManager::GetInstance().AddLog(_T("机械臂"), LOG_ERROR, _T("连接机械臂失败"));
		}
	}
	else
	{
