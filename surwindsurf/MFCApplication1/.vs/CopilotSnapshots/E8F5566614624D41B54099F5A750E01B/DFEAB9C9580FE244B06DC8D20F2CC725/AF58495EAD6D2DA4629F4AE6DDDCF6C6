// 辅助函数
void CMFCApplication1Dlg::UpdateRobotArmStatus()
{
	if (!m_robotArm.IsConnected())
	{
		return;
	}
	
	// 更新状态文本
	CString strStatus;
	RobotArmState state = m_robotArm.GetState();
	
	switch (state)
	{
	case STATE_DISCONNECTED:
		strStatus = _T("未连接");
		break;
	case STATE_CONNECTED:
		strStatus = _T("已连接");
		break;
	case STATE_INITIALIZED:
		strStatus = _T("已初始化");
		break;
	case STATE_MOVING:
		strStatus = _T("运动中");
		break;
	case STATE_ERROR:
		strStatus = _T("错误");
		break;
	}
	
	SetDlgItemText(IDC_STATIC_ROBOT_STATUS, strStatus);
	
	// 更新位置显示
	RobotArmPosition pos = m_robotArm.GetCurrentPosition();
	CString strX, strY, strZ;
	strX.Format(_T("%.2f"), pos.X);
	strY.Format(_T("%.2f"), pos.Y);
	strZ.Format(_T("%.2f"), pos.Z);
	SetDlgItemText(IDC_EDIT_X_POS, strX);
	SetDlgItemText(IDC_EDIT_Y_POS, strY);
	SetDlgItemText(IDC_EDIT_Z_POS, strZ);
}

void CMFCApplication1Dlg::UpdateIOButtonStates()
{
	// 根据硬件连接状态启用/禁用按钮
	BOOL bHardwareConnected = m_ioController.IsHardwareConnected();
	BOOL bInitialized = m_ioController.IsInitialized();
	
	// 控制按钮只有在初始化且硬件连接时才启用
	BOOL bEnableControl = bInitialized && bHardwareConnected;
	
	CWnd* pWnd;
	pWnd = GetDlgItem(IDC_BUTTON_INFUSION_OPEN);
	if (pWnd) pWnd->EnableWindow(bEnableControl);
	
	pWnd = GetDlgItem(IDC_BUTTON_INFUSION_CLOSE);
	if (pWnd) pWnd->EnableWindow(bEnableControl);
	
	pWnd = GetDlgItem(IDC_BUTTON_DISINFECT_OPEN);
	if (pWnd) pWnd->EnableWindow(bEnableControl);
	
	pWnd = GetDlgItem(IDC_BUTTON_DISINFECT_CLOSE);
	if (pWnd) pWnd->EnableWindow(bEnableControl);
	
	pWnd = GetDlgItem(IDC_BUTTON_LASER_OPEN);
	if (pWnd) pWnd->EnableWindow(bEnableControl);
	
	pWnd = GetDlgItem(IDC_BUTTON_LASER_CLOSE);
	if (pWnd) pWnd->EnableWindow(bEnableControl);
	
	// 更新硬件状态显示
	if (bInitialized)
	{
		CString strStatus;
		strStatus.Format(_T("硬件状态: %s"), m_ioController.GetHardwareStateText());
		SetDlgItemText(IDC_STATIC_IO_HW_STATUS, strStatus);
	}
}

void CMFCApplication1Dlg::UpdateIOStatus()
{
	if (!m_ioController.IsInitialized())
	{
		return;
	}
	
	// GPIO会自动在ProcessGPIO中更新，这里只需要显示状态
	
	// 获取当前GPIO输入电平
	BYTE levels = m_ioController.GetGPIOLevels();
	
	// 显示输入状态
	CString strInput1, strInput2, strOutput1, strOutput2;
	
	// 输入1（PIN 1 - 输液传感器）
	strInput1.Format(_T("输液传感器: %s"), 
		(levels & 0x01) ? _T("高") : _T("低"));
	SetDlgItemText(IDC_STATIC_IO1_STATUS, strInput1);
	
	// 输入2（PIN 2 - 消毒液传感器）
	strInput2.Format(_T("消毒液传感器: %s"), 
		(levels & 0x02) ? _T("高") : _T("低"));
	SetDlgItemText(IDC_STATIC_IO2_STATUS, strInput2);
	
	// 输出1（PIN 5 - 输液开关）
	strOutput1.Format(_T("输液开关: %s"), 
		m_ioController.GetInfusionSensorState() ? _T("开") : _T("关"));
	SetDlgItemText(IDC_STATIC_IO3_STATUS, strOutput1);
	
	// 输出2（PIN 6 - 消毒液开关）
	strOutput2.Format(_T("消毒液开关: %s"), 
		m_ioController.GetDisinfectSensorState() ? _T("开") : _T("关"));
	SetDlgItemText(IDC_STATIC_IO4_STATUS, strOutput2);
	
	// 更新按钮状态
	UpdateIOButtonStates();
}

void CMFCApplication1Dlg::ReceiveSerialData(CSerialPort& serial, int nListCtrlId)
{
	if (!serial.IsOpen())
	{
		return;
	}
	
	char szBuffer[1024];
	DWORD dwBytesRead = 0;
	
	if (serial.ReceiveData(szBuffer, sizeof(szBuffer) - 1, dwBytesRead))
	{
		if (dwBytesRead > 0)
		{
			szBuffer[dwBytesRead] = '\0';
			
			// 检查是否为十六进制模式
			BOOL bHex = FALSE;
			if (nListCtrlId == IDC_LIST_RECEIVE232)
			{
				CButton* pCheck = (CButton*)GetDlgItem(IDC_CHECK_HEX232);
				bHex = pCheck ? pCheck->GetCheck() : FALSE;
			}
			else if (nListCtrlId == IDC_LIST_RECEIVE485)
			{
				CButton* pCheck = (CButton*)GetDlgItem(IDC_CHECK_HEX485);
				bHex = pCheck ? pCheck->GetCheck() : FALSE;
			}
			
			// 格式化数据
			CString strData = FormatDataDisplay(szBuffer, dwBytesRead, bHex);
			
			// 添加到列表
			AddSerialDataToList(nListCtrlId, strData, bHex);
		}
	}
}

void CMFCApplication1Dlg::AddSerialDataToList(int nListCtrlId, const CString& strData, BOOL bHex)
{
	CListCtrl* pList = (CListCtrl*)GetDlgItem(nListCtrlId);
	if (!pList)
	{
		return;
	}
	
	// 获取当前时间
	CString strTime = GetCurrentTimeString();
	
	// 添加到列表
	int nIndex = pList->GetItemCount();
	pList->InsertItem(nIndex, strTime);
	pList->SetItemText(nIndex, 1, strData);
	
	// 自动滚动到最新数据
	pList->EnsureVisible(nIndex, FALSE);
	
	// 限制列表数量，避免占用太多内存
	if (pList->GetItemCount() > 1000)
	{
		pList->DeleteItem(0);
	}
}

CString CMFCApplication1Dlg::GetCurrentTimeString()
{
	CTime time = CTime::GetCurrentTime();
	return time.Format(_T("%H:%M:%S"));
}



void CMFCApplication1Dlg::LogCallback(const LogEntry& entry, void* pUserData)
{
	CMFCApplication1Dlg* pDlg = (CMFCApplication1Dlg*)pUserData;
	if (pDlg && pDlg->GetSafeHwnd())
	{
		pDlg->AddLogToList(entry);
	}
}

void CMFCApplication1Dlg::AddLogToList(const LogEntry& entry)
{
	CListCtrl* pList = (CListCtrl*)GetDlgItem(IDC_LIST_LOG);
	if (!pList)
	{
		return;
	}
	
	int nIndex = pList->GetItemCount();
	pList->InsertItem(nIndex, entry.strTime);
	pList->SetItemText(nIndex, 1, entry.strModule);
	
	CString strLevel;
	switch (entry.level)
	{
	case LOG_INFO:
		strLevel = _T("信息");
		break;
	case LOG_WARNING:
		strLevel = _T("警告");
		break;
	case LOG_ERROR:
		strLevel = _T("错误");
		break;
	}
	
	pList->SetItemText(nIndex, 2, strLevel);
	pList->SetItemText(nIndex, 3, entry.strMessage);
	pList->EnsureVisible(nIndex, FALSE);
	
	if (pList->GetItemCount() > 1000)
	{
		pList->DeleteItem(0);
	}
}

CString CMFCApplication1Dlg::FormatDataDisplay(const char* pData, DWORD dwSize, BOOL bHex)
{
	CString strResult;
	
	if (bHex)
	{
		for (DWORD i = 0; i < dwSize; i++)
		{
			CString str;
			str.Format(_T("%02X "), (BYTE)pData[i]);
			strResult += str;
		}
	}
	else
	{
		strResult = CString(pData);
	}
	
	return strResult;
}



