HCURSOR CMFCApplication1Dlg::OnQueryDragIcon()
{
	return static_cast<HCURSOR>(m_hIcon);
}

void CMFCApplication1Dlg::OnDestroy()
{
	// 停止定时器
	KillTimer(TIMER_UPDATE_STATUS);
	KillTimer(TIMER_RECEIVE_DATA);
	
	// 关闭所有设备
	m_serial232.Close();
	m_serial485.Close();
	m_robotArm.Disconnect();
	m_ioController.Shutdown();
	
	CLogManager::GetInstance().AddLog(_T("系统"), LOG_INFO, _T("硬件控制系统关闭"));
	
	CDialogEx::OnDestroy();
}

