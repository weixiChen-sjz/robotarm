#include "pch.h"
#include "IOController.h"
#include "LogManager.h"

#pragma comment(lib, "setupapi.lib")
// 不再需要链接 EVOC_BPI_DLL.lib

CIOController::CIOController()
    : m_GPIOOpen(FALSE)
    , m_GPIOLevels(0)
    , m_GPIOAPreLevels(0)
    , m_bInfusionSwitchOpen(FALSE)
    , m_bDisinfectSwitchOpen(FALSE)
    , m_hBpiDll(NULL)
    , m_pfnBPI_Init(NULL)
    , m_pfnBPI_Deinit(NULL)
    , m_pfnBPI_GPIO_Init(NULL)
    , m_pfnBPI_GPIO_Deinit(NULL)
    , m_pfnBPI_GPIO_SetIoMode(NULL)
    , m_pfnBPI_GPIO_SetLevels(NULL)
    , m_pfnBPI_GPIO_GetLevels(NULL)
    , m_pfnBPI_GPIO_SetPinLevel(NULL)
{
}

CIOController::~CIOController()
{
    Shutdown();
}

// 加载BPI DLL
BOOL CIOController::LoadBpiDll()
{
    // 加载DLL
    m_hBpiDll = LoadLibrary(_T("EVOC_BPI_DLL.dll"));
    if (!m_hBpiDll)
    {
        DWORD dwError = GetLastError();
        CString strMsg;
        strMsg.Format(_T("加载 EVOC_BPI_DLL.dll 失败，错误代码: %d"), dwError);
        CLogManager::GetInstance().AddLog(_T("GPIO"), LOG_ERROR, strMsg);
        return FALSE;
    }
    
    // 获取函数指针
    m_pfnBPI_Init = (PFN_BPI_Init)GetProcAddress(m_hBpiDll, "BPI_Init");
    m_pfnBPI_Deinit = (PFN_BPI_Deinit)GetProcAddress(m_hBpiDll, "BPI_Deinit");
    m_pfnBPI_GPIO_Init = (PFN_BPI_GPIO_Init)GetProcAddress(m_hBpiDll, "BPI_GPIO_Init");
    m_pfnBPI_GPIO_Deinit = (PFN_BPI_GPIO_Deinit)GetProcAddress(m_hBpiDll, "BPI_GPIO_Deinit");
    m_pfnBPI_GPIO_SetIoMode = (PFN_BPI_GPIO_SetIoMode)GetProcAddress(m_hBpiDll, "BPI_GPIO_SetIoMode");
    m_pfnBPI_GPIO_SetLevels = (PFN_BPI_GPIO_SetLevels)GetProcAddress(m_hBpiDll, "BPI_GPIO_SetLevels");
    m_pfnBPI_GPIO_GetLevels = (PFN_BPI_GPIO_GetLevels)GetProcAddress(m_hBpiDll, "BPI_GPIO_GetLevels");
    m_pfnBPI_GPIO_SetPinLevel = (PFN_BPI_GPIO_SetPinLevel)GetProcAddress(m_hBpiDll, "BPI_GPIO_SetPinLevel");
    
    // 检查必需的函数是否都成功获取
    if (!m_pfnBPI_Init || !m_pfnBPI_GPIO_Init || !m_pfnBPI_GPIO_SetIoMode || 
        !m_pfnBPI_GPIO_SetLevels || !m_pfnBPI_GPIO_GetLevels || !m_pfnBPI_GPIO_SetPinLevel)
    {
        CLogManager::GetInstance().AddLog(_T("GPIO"), LOG_ERROR, 
            _T("获取DLL函数指针失败"));
        UnloadBpiDll();
        return FALSE;
    }
    
    CLogManager::GetInstance().AddLog(_T("GPIO"), LOG_INFO, 
        _T("EVOC_BPI_DLL.dll 加载成功"));
    
    return TRUE;
}

// 卸载BPI DLL
void CIOController::UnloadBpiDll()
{
    if (m_hBpiDll)
    {
        FreeLibrary(m_hBpiDll);
        m_hBpiDll = NULL;
    }
    
    // 清空函数指针
    m_pfnBPI_Init = NULL;
    m_pfnBPI_Deinit = NULL;
    m_pfnBPI_GPIO_Init = NULL;
    m_pfnBPI_GPIO_Deinit = NULL;
    m_pfnBPI_GPIO_SetIoMode = NULL;
    m_pfnBPI_GPIO_SetLevels = NULL;
    m_pfnBPI_GPIO_GetLevels = NULL;
    m_pfnBPI_GPIO_SetPinLevel = NULL;
}

// GPIO初始化函数 - 完全按照原程序
BOOL CIOController::Initialize()
{
    // 先加载DLL
    if (!LoadBpiDll())
    {
        AfxMessageBox(_T("加载GPIO库失败！\n请确保 EVOC_BPI_DLL.dll 在程序目录下。"));
        return FALSE;
    }
    
    int Result = BPI_STATUS_FAILED;
    
    // 初始化BPI设备
    Result = m_pfnBPI_Init();
    if (Result != BPI_STATUS_SUCCESSFUL)
    {
        CLogManager::GetInstance().AddLog(_T("GPIO"), LOG_ERROR, _T("BPI_Init 失败"));
        AfxMessageBox(_T("GPIO 打开失败!"));
        UnloadBpiDll();
        return FALSE;
    }
    
    // 初始化GPIO
    unsigned char num;
    Result = m_pfnBPI_GPIO_Init(&num);
    if (Result != BPI_STATUS_SUCCESSFUL)
    {
        m_pfnBPI_Deinit();
        CLogManager::GetInstance().AddLog(_T("GPIO"), LOG_ERROR, _T("BPI_GPIO_Init 失败"));
        AfxMessageBox(_T("GPIO 打开失败!"));
        UnloadBpiDll();
        return FALSE;
    }
    
    CString strMsg;
    strMsg.Format(_T("检测到 %d 个GPIO设备"), (int)num);
    CLogManager::GetInstance().AddLog(_T("GPIO"), LOG_INFO, strMsg);
    
    // 设置IO模式：0x0F = 0b00001111（按照原程序）
    BYTE setIO = 0x0F;
    Result = m_pfnBPI_GPIO_SetIoMode(&setIO, 1);
    if (Result != BPI_STATUS_SUCCESSFUL)
    {
        m_pfnBPI_GPIO_Deinit();
        m_pfnBPI_Deinit();
        CLogManager::GetInstance().AddLog(_T("GPIO"), LOG_ERROR, _T("BPI_GPIO_SetIoMode 失败"));
        AfxMessageBox(_T("GPIO 打开失败!"));
        UnloadBpiDll();
        return FALSE;
    }
    
    // 初始化所有输出为0（关闭状态）
    setIO = 0;
    m_pfnBPI_GPIO_SetLevels(&setIO, 1);
    
    // 标记GPIO已打开
    m_GPIOOpen = TRUE;
    
    CLogManager::GetInstance().AddLog(_T("GPIO"), LOG_INFO, 
        _T("GPIO初始化成功：输入(PIN 1-4) 输出(PIN 5-8)"));
    
    return TRUE;
}

// GPIO读写函数 - 完全按照原程序的GPIO_ReadWrite
void CIOController::ProcessGPIO()
{
    // 判断GPIO是否打开成功
    if (!m_GPIOOpen || !m_pfnBPI_GPIO_GetLevels)
    {
        m_GPIOLevels = 0;
        return;
    }

    // 读取GPIO输入（1-4号端口）
    m_pfnBPI_GPIO_GetLevels(&m_GPIOLevels, 1);
    
    // 1号IO（PIN 1 - 输液传感器）
    if ((m_GPIOLevels & 0x1) && !(m_GPIOAPreLevels & 0x1))
    {
        // 上升沿 - 从低到高
        CLogManager::GetInstance().AddLog(_T("GPIO输入"), LOG_INFO, 
            _T("PIN 1 上升沿：输液传感器检测到液体"));
    }
    
    // 检测下降沿
    if (!(m_GPIOLevels & 0x1) && (m_GPIOAPreLevels & 0x1))
    {
        // 下降沿 - 从高到低
        CLogManager::GetInstance().AddLog(_T("GPIO输入"), LOG_WARNING, 
            _T("PIN 1 下降沿：输液传感器液体不足"));
    }

    // 2号IO（PIN 2 - 消毒液传感器）
    if ((m_GPIOLevels & 0x2) && !(m_GPIOAPreLevels & 0x2))
    {
        CLogManager::GetInstance().AddLog(_T("GPIO输入"), LOG_INFO, 
            _T("PIN 2 上升沿：消毒液传感器检测到液体"));
    }
    
    if (!(m_GPIOLevels & 0x2) && (m_GPIOAPreLevels & 0x2))
    {
        CLogManager::GetInstance().AddLog(_T("GPIO输入"), LOG_WARNING, 
            _T("PIN 2 下降沿：消毒液液位低"));
    }

    // 3号IO（PIN 3 - 保留）
    if ((m_GPIOLevels & 0x4) && !(m_GPIOAPreLevels & 0x4))
    {
        CLogManager::GetInstance().AddLog(_T("GPIO输入"), LOG_INFO, 
            _T("PIN 3 上升沿检测"));
    }

    // 4号IO（PIN 4 - 保留）
    if ((m_GPIOLevels & 0x8) && !(m_GPIOAPreLevels & 0x8))
    {
        CLogManager::GetInstance().AddLog(_T("GPIO输入"), LOG_INFO, 
            _T("PIN 4 上升沿检测"));
    }

    // 设置GPIO输出（5-8号端口）
    if (!m_pfnBPI_GPIO_SetPinLevel)
        return;
        
    // PIN 5 - 输液开关
    if (m_bInfusionSwitchOpen)
    {
        m_pfnBPI_GPIO_SetPinLevel(5, 1);
    }
    else
    {
        m_pfnBPI_GPIO_SetPinLevel(5, 0);
    }

    // PIN 6 - 消毒液开关
    if (m_bDisinfectSwitchOpen)
    {
        m_pfnBPI_GPIO_SetPinLevel(6, 1);
    }
    else
    {
        m_pfnBPI_GPIO_SetPinLevel(6, 0);
    }

    // PIN 7 - 保留
    m_pfnBPI_GPIO_SetPinLevel(7, 0);

    // PIN 8 - 保留
    m_pfnBPI_GPIO_SetPinLevel(8, 0);

    // 保存当前输入状态用于下次边缘检测
    m_GPIOAPreLevels = m_GPIOLevels;
}

void CIOController::Shutdown()
{
    if (!m_GPIOOpen)
    {
        return;
    }
    
    // 关闭所有输出
    if (m_pfnBPI_GPIO_SetLevels)
    {
        BYTE levels = 0x00;
        m_pfnBPI_GPIO_SetLevels(&levels, 1);
    }
    
    // 关闭GPIO
    if (m_pfnBPI_GPIO_Deinit)
    {
        m_pfnBPI_GPIO_Deinit();
    }
    
    if (m_pfnBPI_Deinit)
    {
        m_pfnBPI_Deinit();
    }
    
    m_GPIOOpen = FALSE;
    m_bInfusionSwitchOpen = FALSE;
    m_bDisinfectSwitchOpen = FALSE;
    
    // 卸载DLL
    UnloadBpiDll();
    
    CLogManager::GetInstance().AddLog(_T("GPIO"), LOG_INFO, _T("GPIO已关闭"));
}

// 业务层封装方法
BOOL CIOController::OpenInfusionSwitch()
{
    if (!m_GPIOOpen || !m_pfnBPI_GPIO_SetPinLevel)
    {
        return FALSE;
    }
    
    m_bInfusionSwitchOpen = TRUE;
    m_pfnBPI_GPIO_SetPinLevel(5, 1);
    
    CLogManager::GetInstance().AddLog(_T("GPIO输出"), LOG_INFO, 
        _T("PIN 5 输液开关已打开"));
    
    return TRUE;
}

BOOL CIOController::CloseInfusionSwitch()
{
    if (!m_GPIOOpen || !m_pfnBPI_GPIO_SetPinLevel)
    {
        return FALSE;
    }
    
    m_bInfusionSwitchOpen = FALSE;
    m_pfnBPI_GPIO_SetPinLevel(5, 0);
    
    CLogManager::GetInstance().AddLog(_T("GPIO输出"), LOG_INFO, 
        _T("PIN 5 输液开关已关闭"));
    
    return TRUE;
}

