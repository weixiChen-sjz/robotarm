BOOL CProcedureController::WaitForMotorComplete(int nTimeoutMs)
{
    // ★ 电机不返回信号，改为超时等待
    ULONGLONG dwStart = GetTickCount64();  // ★ 使用64位计时
    
    // ★ 分段等待，每200ms检查停止/暂停请求
    while ((GetTickCount64() - dwStart) < (ULONGLONG)nTimeoutMs)
    {
        // 检查停止请求
        if (m_bStopRequest)
        {
            LogWarning(_T("收到停止请求，中断等待"));
            return FALSE;
        }
        
        // 检查暂停请求
        while (m_bPauseRequest)
        {
            Sleep(100);
            if (m_bStopRequest)
                return FALSE;
        }
        
        Sleep(200);
    }
    
    // 超时时间到，假设电机已完成
    LogInfo(_T("电机动作等待完成（已等待 %d 毫秒）"), nTimeoutMs);
    return TRUE;
}
```

