void CLogManager::AddLog(CString source, LogType type, CString message)
{
    EnterCriticalSection(&m_cs);
    
    // 日志文件输出
    if (m_logFile.m_hFile != CFile::hFileNull)
    {
        CString strLine;
        strLine.Format(_T("[%s] [%s] %s: %s\r\n"),
            GetCurrentTimeString(), source, GetLogTypeString(type), message);
        
        CStringA strUTF8 = CT2A(strLine, CP_UTF8);
        m_logFile.Write(strUTF8.GetString(), strUTF8.GetLength());
    }
    
    // 内存管理（最大10000条）
    if (m_logs.size() >= 10000)
    {
        m_logs.erase(m_logs.begin());
    }
    
    m_logs.push_back(logEntry);
    
    LeaveCriticalSection(&m_cs);
}
