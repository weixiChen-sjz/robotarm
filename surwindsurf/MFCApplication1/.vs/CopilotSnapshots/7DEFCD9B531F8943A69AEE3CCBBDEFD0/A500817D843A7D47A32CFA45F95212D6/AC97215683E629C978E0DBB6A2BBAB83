float CProcedureController::GetLaserDistance()
{
    // ★ 1. 发送测距指令（十六进制）
    BYTE cmdBuffer[] = { 0x01, 0x04, 0x00, 0x18, 0x00, 0x02, 0xF1, 0xCC };
    m_pSerial485->SendData((char*)cmdBuffer, sizeof(cmdBuffer), FALSE);
    
    // ★ 2. 等待响应
    Sleep(100);
    
    // ★ 3. 接收并解析数据
    char szBuffer[256];
    DWORD dwBytesRead = 0;
    if (m_pSerial485->ReceiveData(szBuffer, 255, dwBytesRead))
    {
        float fDistance = 0.0f;
        if (CSerialPort::ParseLaserDistance(szBuffer, dwBytesRead, fDistance))
        {
            // ★ 4. 激光测距仪实际有效范围：120mm ~ 280mm
            // ParseLaserDistance内部已做换算：fDistance = 200.0f - fRawValue
            // 返回值为相对零点（200mm）的距离
            // 正常工作范围：约 100mm ~ 120mm（目标高度±20mm）
            if (fDistance >= 80.0f && fDistance <= 300.0f)  // ★ 宽松验证
                return fDistance;
        }
    }
    
    // 读取失败，返回模拟值
    LogWarning(_T("无法读取激光距离，使用模拟值"));
    return 100.0f;
}
```

