### 步骤6：穿刺执行⭐ 232电机控制

**目标**：通过232串口控制电机完成进针动作

#### 工作流程
```
计算穿刺深度 → 232发送电机指令 → 监听到位信号 → 确认完成
```

#### 代码实现
```cpp
bool ProcedureController::Step6_Puncture() {
    LogInfo("步骤6：穿刺执行开始");
    
    // 1. 获取穿刺深度参数（可从UI或配置读取）
    float punctureDepth = 50.0f;  // 示例：50mm
    
    LogInfo("目标穿刺深度: %.2fmm", punctureDepth);
    
    // 2. 发送电机移动指令
    CString strCmd;
    strCmd.Format("MOVE %.2f\r\n", punctureDepth);
    
    if (!SendMotorCommand(strCmd)) {
        LogError("发送电机指令失败");
        return false;
    }
    
    // 3. 等待电机到位信号
    if (!WaitForMotorArrival(10000)) {  // 10秒超时
        LogError("电机到位超时");
        // 发送停止指令
        SendMotorCommand("STOP\r\n");
        return false;
    }
    
    LogInfo("步骤6：穿刺执行完成，深度=%.2fmm", punctureDepth);
    return true;
}

// 发送232电机指令
bool ProcedureController::SendMotorCommand(const CString& cmd) {
    if (!m_motorSerial.IsOpen()) {
        LogError("232串口未打开");
        return false;
    }
    
    CStringA cmdA(cmd);
    BOOL result = m_motorSerial.SendData(cmdA.GetString(), 
                                         cmdA.GetLength(), 
                                         TRUE);  // 自动添加终止符
    
    if (result) {
        LogInfo("发送电机指令: %s", (LPCTSTR)cmd.Left(cmd.GetLength()-2));
    } else {
        LogError("电机指令发送失败");
    }
    
    return result == TRUE;
}

// 等待电机到位信号
bool ProcedureController::WaitForMotorArrival(DWORD timeout) {
    DWORD startTime = GetTickCount();
    char buffer[256];
    DWORD bytesRead = 0;
    
    LogInfo("等待电机到位信号...");
    
    while (GetTickCount() - startTime < timeout) {
        // 读取232串口数据
        if (m_motorSerial.ReceiveData(buffer, sizeof(buffer)-1, bytesRead)) {
            if (bytesRead > 0) {
                buffer[bytesRead] = '\0';
                CString response(buffer);
                
                LogInfo("电机响应: %s", (LPCTSTR)response);
                
                // 检查响应
                if (response.Find(_T("ARRIVED")) >= 0) {
                    LogInfo("电机已到达目标位置");
                    return true;
                }
                
                if (response.Find(_T("ERROR")) >= 0) {
                    LogError("电机报错: %s", (LPCTSTR)response);
                    return false;
                }
            }
        }
        
        Sleep(50);  // 50ms轮询间隔
    }
    
    LogError("等待电机到位超时");
    return false;
}
