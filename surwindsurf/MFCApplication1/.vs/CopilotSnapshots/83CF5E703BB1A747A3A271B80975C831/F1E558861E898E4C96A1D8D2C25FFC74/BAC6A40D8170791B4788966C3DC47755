### 步骤2：激光粗调高度（闭环控制）

**目标**：调整机械臂Z轴高度到距离目标表面 100mm ±2mm

#### 工作流程
```
打开激光电源 → 读取距离 → 计算误差 → 调整Z轴 → 循环至误差≤2mm → 关闭激光
```

#### 代码实现
```cpp
bool ProcedureController::Step2_LaserCoarseAdjust() {
    LogInfo("步骤2：激光粗调高度开始");
    
    const float TARGET_DISTANCE = 100.0f;  // 目标距离 100mm
    const float TOLERANCE = 2.0f;          // 允许误差 ±2mm
    const int MAX_ITERATIONS = 20;         // 最大调整次数
    const float DAMPING = 0.8f;            // 阻尼系数（防止震荡）
    
    // 1. 打开激光测距仪电源
    if (!m_ioCtrl.OpenLaserSwitch()) {
        LogError("打开激光测距仪失败");
        return false;
    }
    Sleep(500);  // 等待激光稳定
    
    // 2. 闭环调整
    for (int i = 0; i < MAX_ITERATIONS; i++) {
        // 读取当前距离
        float currentDistance = ReadLaserDistance();
        if (currentDistance < 0) {
            LogError("读取激光距离失败");
            m_ioCtrl.CloseLaserSwitch();
            return false;
        }
        
        // 计算误差
        float error = currentDistance - TARGET_DISTANCE;
        
        LogInfo("迭代%d: 当前距离=%.2fmm, 目标=%.2fmm, 误差=%.2fmm", 
                i+1, currentDistance, TARGET_DISTANCE, error);
        
        // 判断是否达到精度
        if (fabs(error) <= TOLERANCE) {
            LogInfo("高度调整完成，误差=%.2fmm", error);
            break;
        }
        
        // 计算Z轴调整量（带阻尼）
        float zAdjust = -error * DAMPING;  // 负号：距离大→下移
        
        // 获取当前位置并调整Z轴
        RobotArmPosition currentPos = m_robot.GetCurrentPosition();
        currentPos.Z += zAdjust;
        
        // 移动机械臂
        if (!m_robot.MoveTo(currentPos, 30)) {  // 低速移动
            LogError("机械臂Z轴调整失败");
            m_ioCtrl.CloseLaserSwitch();
            return false;
        }
        
        Sleep(200);  // 等待稳定
    }
    
    // 3. 关闭激光（节省电力，避免干扰后续视觉识别）
    m_ioCtrl.CloseLaserSwitch();
    
    LogInfo("步骤2：激光粗调高度完成");
    return true;
}
```

