bool ProcedureController::Step3_PostureAdjust() {
    LogInfo("步骤3：姿态调整开始");
    
    // 1. 视觉识别穿刺点
    if (!m_vision || !m_vision->IsReady()) {
        LogError("视觉系统未就绪");
