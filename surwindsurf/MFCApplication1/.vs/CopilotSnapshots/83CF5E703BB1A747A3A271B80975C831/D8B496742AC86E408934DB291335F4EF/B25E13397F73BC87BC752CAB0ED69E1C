void CProcedureDlg::ReadParamsFromUI()
{
	CString strValue;
	
	GetDlgItemText(IDC_EDIT_TARGET_HEIGHT, strValue);
	m_params.fTargetHeight = (float)_ttof(strValue);
	
	GetDlgItemText(IDC_EDIT_COARSE_TOLERANCE, strValue);
	m_params.fCoarseTolerance = (float)_ttof(strValue);
	
	GetDlgItemText(IDC_EDIT_FINE_TOLERANCE, strValue);
	m_params.fFineTolerance = (float)_ttof(strValue);
	
	GetDlgItemText(IDC_EDIT_PUNCTURE_DEPTH, strValue);
	m_params.fPunctureDepth = (float)_ttof(strValue);
	
	GetDlgItemText(IDC_EDIT_DISINFECT_TIME, strValue);
	m_params.fDisinfectTime = (float)_ttof(strValue);
	
	GetDlgItemText(IDC_EDIT_SAFE_HEIGHT, strValue);
	m_params.fSafeHeight = (float)_ttof(strValue);
	
	CButton* pCheck = (CButton*)GetDlgItem(IDC_CHECK_ENABLE_VISION);
	m_params.bEnableVision = pCheck ? pCheck->GetCheck() : FALSE;
}

void CProcedureDlg::DisplayParamsToUI()
{
	CString strValue;
	
	strValue.Format(_T("%.1f"), m_params.fTargetHeight);
	SetDlgItemText(IDC_EDIT_TARGET_HEIGHT, strValue);
	
	strValue.Format(_T("%.1f"), m_params.fCoarseTolerance);
	SetDlgItemText(IDC_EDIT_COARSE_TOLERANCE, strValue);
	
	strValue.Format(_T("%.1f"), m_params.fFineTolerance);
	SetDlgItemText(IDC_EDIT_FINE_TOLERANCE, strValue);
	
	strValue.Format(_T("%.1f"), m_params.fPunctureDepth);
	SetDlgItemText(IDC_EDIT_PUNCTURE_DEPTH, strValue);
	
	strValue.Format(_T("%.1f"), m_params.fDisinfectTime);
	SetDlgItemText(IDC_EDIT_DISINFECT_TIME, strValue);
	
	strValue.Format(_T("%.1f"), m_params.fSafeHeight);
	SetDlgItemText(IDC_EDIT_SAFE_HEIGHT, strValue);
	
	CButton* pCheck = (CButton*)GetDlgItem(IDC_CHECK_ENABLE_VISION);
	if (pCheck)
	{
		pCheck->SetCheck(m_params.bEnableVision);
	}
}

