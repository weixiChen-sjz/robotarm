void CProcedureDlg::ExportProcedureParams()
{
	// 从界面读取参数
	ReadParamsFromUI();
	
	CFileDialog dlg(FALSE, _T("txt"), _T("procedure_params.txt"),
		OFN_HIDEREADONLY | OFN_OVERWRITEPROMPT,
		_T("参数文件 (*.txt)|*.txt|所有文件 (*.*)|*.*||"));
	
	if (dlg.DoModal() == IDOK)
	{
		CStdioFile file;
		if (file.Open(dlg.GetPathName(), CFile::modeCreate | CFile::modeWrite | CFile::typeText))
		{
			CString strContent;
			strContent.Format(
				_T("医疗穿刺流程参数配置\r\n")
				_T("=====================================\r\n\r\n")
				_T("步骤2 - 激光粗调参数：\r\n")
				_T("  目标高度: %.2f mm\r\n")
				_T("  粗调精度: ±%.2f mm\r\n\r\n")
				_T("步骤4 - 精准对位参数：\r\n")
				_T("  精调精度: ±%.2f mm\r\n")
				_T("  最大调整次数: %d\r\n\r\n")
				_T("步骤5 - 消毒参数：\r\n")
				_T("  消毒时间: %.2f 秒\r\n\r\n")
				_T("步骤6 - 穿刺参数：\r\n")
				_T("  穿刺深度: %.2f mm\r\n")
				_T("  穿刺速度: %.2f %%\r\n\r\n")
				_T("安全参数：\r\n")
				_T("  安全高度: %.2f mm\r\n")
				_T("  启用视觉: %s\r\n")
				_T("  单步超时: %d 秒\r\n"),
				m_params.fTargetHeight,
				m_params.fCoarseTolerance,
				m_params.fFineTolerance,
				m_params.nMaxAdjustCount,
				m_params.fDisinfectTime,
				m_params.fPunctureDepth,
				m_params.fPunctureSpeed,
				m_params.fSafeHeight,
				m_params.bEnableVision ? _T("是") : _T("否"),
				m_params.nStepTimeout
			);
			
			file.WriteString(strContent);
			file.Close();
			
			CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO, _T("参数已导出到文件"));
			MessageBox(_T("参数导出成功！"), _T("提示"), MB_OK | MB_ICONINFORMATION);
		}
		else
		{
			MessageBox(_T("导出参数失败！"), _T("错误"), MB_OK | MB_ICON_ERROR);
		}
	}
}
