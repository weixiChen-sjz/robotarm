#pragma once
#include "afxdialogex.h"
#include "Resource.h"

// CProcedureDlg 对话框

class CProcedureDlg : public CDialogEx
{
	DECLARE_DYNAMIC(CProcedureDlg)

public:
	CProcedureDlg(CWnd* pParent = nullptr);   // 标准构造函数
	virtual ~CProcedureDlg();

// 对话框数据
#ifdef AFX_DESIGN_TIME
	enum { IDD = IDD_PROCEDURE_DIALOG };
#endif

protected:
	virtual void DoDataExchange(CDataExchange* pDX);    // DDX/DDV 支持
	virtual BOOL OnInitDialog();

	DECLARE_MESSAGE_MAP()

public:
	// ========== 流程控制相关成员变量 ==========
	BOOL m_bProcedureRunning;        // 流程是否正在运行
	int m_nCurrentStep;              // 当前步骤（0-7）
	
	// 流程参数
	float m_fPunctureDepth;          // 穿刺深度（mm）
	float m_fSafeHeight;             // 安全高度（mm）
	float m_fCoarsePrecision;        // 粗调精度（mm）
	float m_fFinePrecision;          // 精调精度（mm）
	float m_fDisinfectTime;          // 消毒时间（s）
	
	// ========== 消息处理函数 ==========
	
	// 流程控制按钮
	afx_msg void OnBnClickedButtonStartProcedure();
	afx_msg void OnBnClickedButtonStopProcedure();
	afx_msg void OnBnClickedButtonEmergencyStop();
	
	// 参数操作按钮
	afx_msg void OnBnClickedButtonSaveParams();
	afx_msg void OnBnClickedButtonResetParams();
	afx_msg void OnBnClickedButtonExportParams();
	
	// 单步测试按钮
	afx_msg void OnBnClickedButtonStep2Test();
	afx_msg void OnBnClickedButtonStep4Test();
	afx_msg void OnBnClickedButtonStep5Test();
	afx_msg void OnBnClickedButtonStep6Test();
	afx_msg void OnBnClickedButtonStep7Test();
	
	// 日志操作
	afx_msg void OnBnClickedButtonClearProcedureLog();
	
	// ========== 辅助函数 ==========
	
	// 初始化控件
	void InitializeControls();
	
	// 更新流程状态显示
	void UpdateProcedureStatus();
	
	// 更新步骤监控列表
	void UpdateStepMonitor(int stepNumber, CString status, CString time, CString note);
	
	// 加载/保存流程参数
	void LoadProcedureParams();
	void SaveProcedureParams();
	void ResetProcedureParams();
	
	// 添加操作日志
	void AddProcedureLog(const CString& strLog);
	
	// 获取主对话框指针（用于访问硬件设备）
	class CMFCApplication1Dlg* GetMainDlg();
