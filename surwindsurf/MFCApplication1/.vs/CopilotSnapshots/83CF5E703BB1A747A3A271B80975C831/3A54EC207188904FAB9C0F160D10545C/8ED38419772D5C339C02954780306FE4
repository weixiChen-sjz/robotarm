void CProcedureDlg::OnBnClickedButtonExportParams()
{
	CFileDialog dlg(FALSE, _T("txt"), _T("procedure_params.txt"), 
		OFN_HIDEREADONLY | OFN_OVERWRITEPROMPT,
		_T("文本文件 (*.txt)|*.txt|所有文件 (*.*)|*.*||"));
	
	if (dlg.DoModal() == IDOK)
	{
		CStdioFile file;
		if (file.Open(dlg.GetPathName(), CFile::modeCreate | CFile::modeWrite | CFile::typeText))
		{
			CString strContent;
			strContent.Format(_T("流程参数导出\r\n\r\n")
				_T("穿刺深度: %.2f mm\r\n")
				_T("安全高度: %.2f mm\r\n")
				_T("粗调精度: %.2f mm\r\n")
				_T("精调精度: %.2f mm\r\n")
				_T("消毒时间: %.2f s\r\n"),
				m_fPunctureDepth, m_fSafeHeight, m_fCoarsePrecision, 
				m_fFinePrecision, m_fDisinfectTime);
			
			file.WriteString(strContent);
			file.Close();
			
			AddProcedureLog(_T("参数已导出到文件"));
			MessageBox(_T("导出参数成功！"), _T("提示"), MB_OK | MB_ICONINFORMATION);
		}
		else
		{
			MessageBox(_T("导出参数失败！"), _T("错误"), MB_OK | MB_ICONERROR);
		}
	}
}

