void CProcedureDlg::OnBnClickedButtonStartProcedure()
{
	if (m_bProcedureRunning)
	{
		MessageBox(_T("流程正在运行中！"), _T("提示"), MB_OK | MB_ICONINFORMATION);
		return;
	}
	
	// 获取主对话框
	CMFCApplication1Dlg* pMainDlg = GetMainDlg();
	if (!pMainDlg)
	{
		AddProcedureLog(_T("错误：无法获取主对话框"));
		return;
	}
	
	// 检查硬件连接状态
	// TODO: 添加硬件检查逻辑
	
	if (MessageBox(_T("确认开始执行完整流程？"), _T("确认"), MB_YESNO | MB_ICONQUESTION) != IDYES)
	{
		return;
	}
	
	// 保存参数
	SaveProcedureParams();
	
	// 设置运行状态
	m_bProcedureRunning = TRUE;
	m_nCurrentStep = 0;
	
	// 更新UI
	UpdateProcedureStatus();
	GetDlgItem(IDC_BUTTON_START_PROCEDURE)->EnableWindow(FALSE);
	GetDlgItem(IDC_BUTTON_STOP_PROCEDURE)->EnableWindow(TRUE);
	
	// 添加日志
	AddProcedureLog(_T("========== 开始执行穿刺流程 =========="));
	
	// TODO: 启动流程执行线程或调用 ProcedureController
	
	MessageBox(_T("流程控制器尚未实现！\n\n需要实现 ProcedureController 类。"), 
		_T("提示"), MB_OK | MB_ICONINFORMATION);
	
	// 恢复状态
	m_bProcedureRunning = FALSE;
	UpdateProcedureStatus();
	GetDlgItem(IDC_BUTTON_START_PROCEDURE)->EnableWindow(TRUE);
	GetDlgItem(IDC_BUTTON_STOP_PROCEDURE)->EnableWindow(FALSE);
}

void CProcedureDlg::OnBnClickedButtonStopProcedure()
{
	if (!m_bProcedureRunning)
	{
		return;
	}
	
	if (MessageBox(_T("确认停止当前流程？"), _T("确认"), MB_YESNO | MB_ICONQUESTION) != IDYES)
	{
		return;
	}
	
	// TODO: 调用 ProcedureController::StopProcedure()
	
	m_bProcedureRunning = FALSE;
	UpdateProcedureStatus();
	
	AddProcedureLog(_T("用户手动停止流程"));
	
	GetDlgItem(IDC_BUTTON_START_PROCEDURE)->EnableWindow(TRUE);
	GetDlgItem(IDC_BUTTON_STOP_PROCEDURE)->EnableWindow(FALSE);
}

