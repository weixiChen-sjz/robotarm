void CProcedureDlg::AddProcedureLog(const CString& strLog)
{
	CString strExisting;
	GetDlgItemText(IDC_EDIT_PROCEDURE_LOG, strExisting);
	
	// 获取当前时间
	CTime time = CTime::GetCurrentTime();
	CString strTime = time.Format(_T("[%H:%M:%S] "));
	
	// 添加新日志
	CString strNew = strTime + strLog + _T("\r\n") + strExisting;
	
	// 限制日志长度（保留最近1000行）
	int nLines = 0;
	int nPos = 0;
	while ((nPos = strNew.Find(_T("\r\n"), nPos)) != -1)
	{
		nLines++;
		nPos += 2;
		if (nLines > 1000)
		{
			strNew = strNew.Left(nPos);
			break;
		}
	}
	
	SetDlgItemText(IDC_EDIT_PROCEDURE_LOG, strNew);
	
	// 同时添加到系统日志
	CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO, strLog);
}

