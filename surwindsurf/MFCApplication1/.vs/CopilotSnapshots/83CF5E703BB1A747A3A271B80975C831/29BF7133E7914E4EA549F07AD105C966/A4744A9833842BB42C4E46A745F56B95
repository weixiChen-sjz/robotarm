// CProcedureDlg 消息处理程序

BOOL CProcedureDlg::OnInitDialog()
{
	CDialogEx::OnInitDialog();

	// 初始化控件
	InitializeControls();
	
	// 加载流程参数
	LoadProcedureParams();
	
	// 初始化流程控制器
	InitializeController();
	
	// 更新流程状态
	UpdateProcedureStatus();
	
	// 启动定时器（200ms）
	SetTimer(TIMER_UPDATE_PROCEDURE, 200, NULL);
	
	// 记录日志
	CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO, _T("流程控制面板已打开"));
	
	m_bInitialized = TRUE;

	return TRUE;
}

void CProcedureDlg::OnOK()
{
	// 防止Enter键关闭对话框
	// 不调用基类的OnOK()
}

void CProcedureDlg::OnCancel()
{
	// 检查是否正在运行
	if (m_controller.GetState() == PROC_STATE_RUNNING)
	{
		if (MessageBox(_T("流程正在运行中！\n\n确认关闭流程控制面板？"), 
			_T("确认"), MB_YESNO | MB_ICONQUESTION) != IDYES)
		{
			return;
		}
		
		// 停止流程
		m_controller.StopProcedure();
	}
	
	CDialogEx::OnCancel();
}

void CProcedureDlg::OnDestroy()
{
	// 停止定时器
	KillTimer(TIMER_UPDATE_PROCEDURE);
	
	// 停止流程
	if (m_controller.GetState() == PROC_STATE_RUNNING)
	{
		m_controller.StopProcedure();
	}
	
	CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO, _T("流程控制面板已关闭"));
	
	CDialogEx::OnDestroy();
}

void CProcedureDlg::OnTimer(UINT_PTR nIDEvent)
{
	if (nIDEvent == TIMER_UPDATE_PROCEDURE)
	{
		// 更新流程状态
		UpdateProcedureStatus();
		
		// 更新实时数据
		UpdateRealTimeData();
	}
	
	CDialogEx::OnTimer(nIDEvent);
}

// ========== 初始化函数 ==========

void CProcedureDlg::InitializeControls()
{
	// 初始化步骤监控列表
	CListCtrl* pList = (CListCtrl*)GetDlgItem(IDC_LIST_STEP_MONITOR);
	if (pList)
	{
		pList->SetExtendedStyle(LVS_EX_FULLROWSELECT | LVS_EX_GRIDLINES);
		pList->InsertColumn(0, _T("步骤"), LVCFMT_CENTER, 60);
		pList->InsertColumn(1, _T("名称"), LVCFMT_LEFT, 120);
		pList->InsertColumn(2, _T("状态"), LVCFMT_CENTER, 100);
		pList->InsertColumn(3, _T("耗时"), LVCFMT_CENTER, 80);
		pList->InsertColumn(4, _T("备注"), LVCFMT_LEFT, 200);
		
		// 添加7个步骤
		const CString stepNames[] = {
			_T("视觉定位（YOLO识别模型）"),
			_T("激光粗调（高度±2mm）"),
			_T("识别穿刺点（视觉）"),
			_T("精准对位（姿态+±0.2mm）"),
			_T("喷消毒液（2秒）"),
			_T("穿刺执行（电机）"),
			_T("输液启动（开阀）")
		};
		
		for (int i = 0; i < 7; i++)
		{
			CString strStep;
			strStep.Format(_T("步骤%d"), i + 1);
			int nIndex = pList->InsertItem(i, strStep);
			pList->SetItemText(nIndex, 1, stepNames[i]);
			pList->SetItemText(nIndex, 2, _T("○ 待执行"));
			pList->SetItemText(nIndex, 3, _T("-"));
			pList->SetItemText(nIndex, 4, _T("-"));
		}
	}
	
	// 初始化流程参数显示
	DisplayParamsToUI();
	
	// 初始化流程状态显示
	SetDlgItemText(IDC_STATIC_PROCEDURE_STATUS, _T("流程状态: ● 就绪"));
	SetDlgItemText(IDC_STATIC_CURRENT_STEP, _T("当前步骤: 【无】"));
	
	// 初始化进度条
	CProgressCtrl* pProgress = (CProgressCtrl*)GetDlgItem(IDC_PROGRESS_PROCEDURE);
	if (pProgress)
	{
		pProgress->SetRange(0, 100);
		pProgress->SetPos(0);
	}
	
	// 初始化实时数据显示
	SetDlgItemText(IDC_STATIC_LASER_DISTANCE, _T("激光距离: -- mm"));
	SetDlgItemText(IDC_STATIC_DISTANCE_ERROR, _T("误差: -- mm"));
	SetDlgItemText(IDC_STATIC_ROBOT_POSITION, _T("机械臂位置: X:-- Y:-- Z:-- Theta:--°"));
	SetDlgItemText(IDC_STATIC_VISION_COORD, _T("视觉坐标: (未启用)"));
}

void CProcedureDlg::InitializeController()
{
	// 获取主对话框
	CMFCApplication1Dlg* pMainDlg = GetMainDlg();
	if (!pMainDlg)
	{
		CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_ERROR, 
			_T("无法获取主对话框指针"));
		return;
	}
	
	// 设置硬件设备接口
	m_controller.SetRobotArm(&pMainDlg->m_robotArm);
	m_controller.SetSerial232(&pMainDlg->m_serial232);
	m_controller.SetSerial485(&pMainDlg->m_serial485);
	m_controller.SetIOController(&pMainDlg->m_ioController);
	
	// 设置视觉系统（暂时使用模拟系统）
	if (m_params.bEnableVision)
	{
		// TODO: 集成真实视觉系统后替换
		// m_controller.SetVisionSystem(new CRealSenseVisionSystem());
		CMockVisionSystem* pMockVision = new CMockVisionSystem();
		m_controller.SetVisionSystem(pMockVision);
		
		CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_WARNING, 
			_T("当前使用模拟视觉系统"));
	}
	
	// 设置流程参数
	m_controller.SetParams(m_params);
	
	// 设置回调函数
	m_controller.SetStateChangeCallback(OnStateChanged, this);
	m_controller.SetStepChangeCallback(OnStepChanged, this);
	
	CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO, 
		_T("流程控制器初始化完成"));
}

// ========== 更新函数 ==========

void CProcedureDlg::UpdateProcedureStatus()
{
	ProcedureState state = m_controller.GetState();
	int nCurrentStep = m_controller.GetCurrentStep();
	
	// 更新状态文本
	CString strStatus;
	switch (state)
	{
	case PROC_STATE_IDLE:
		strStatus = _T("流程状态: ● 就绪");
		break;
	case PROC_STATE_RUNNING:
		strStatus = _T("流程状态: ? 运行中");
		break;
	case PROC_STATE_PAUSED:
		strStatus = _T("流程状态: ? 已暂停");
		break;
	case PROC_STATE_STOPPED:
		strStatus = _T("流程状态: ■ 已停止");
		break;
	case PROC_STATE_COMPLETED:
		strStatus = _T("流程状态: ? 已完成");
		break;
	case PROC_STATE_ERROR:
		strStatus = _T("流程状态: ? 错误");
		break;
	}
	SetDlgItemText(IDC_STATIC_PROCEDURE_STATUS, strStatus);
	
	// 更新当前步骤
	CString strStep;
	if (nCurrentStep > 0 && nCurrentStep <= 7)
	{
		strStep.Format(_T("当前步骤: 【步骤%d - %s】"), 
			nCurrentStep, m_controller.GetStepName(nCurrentStep));
	}
	else
	{
		strStep = _T("当前步骤: 【无】");
	}
	SetDlgItemText(IDC_STATIC_CURRENT_STEP, strStep);
	
	// 更新进度条
	CProgressCtrl* pProgress = (CProgressCtrl*)GetDlgItem(IDC_PROGRESS_PROCEDURE);
	if (pProgress)
	{
		int nProgress = (int)m_controller.GetProgress();
		pProgress->SetPos(nProgress);
	}
	
	// 更新按钮状态
	BOOL bRunning = (state == PROC_STATE_RUNNING);
	BOOL bPaused = (state == PROC_STATE_PAUSED);
	
	CWnd* pWnd;
	pWnd = GetDlgItem(IDC_BUTTON_START_PROCEDURE);
	if (pWnd) pWnd->EnableWindow(!bRunning && !bPaused);
	
	pWnd = GetDlgItem(IDC_BUTTON_STOP_PROCEDURE);
	if (pWnd) pWnd->EnableWindow(bRunning || bPaused);
	
	pWnd = GetDlgItem(IDC_BUTTON_PAUSE_PROCEDURE);
	if (pWnd)
	{
		pWnd->EnableWindow(bRunning || bPaused);
		pWnd->SetWindowText(bPaused ? _T("恢复") : _T("暂停"));
	}
	
	// 禁用参数编辑（运行时）
	EnableControls(!bRunning && !bPaused);
}

void CProcedureDlg::UpdateStepMonitor(int stepNumber, CString status, CString time, CString note)
{
	CListCtrl* pList = (CListCtrl*)GetDlgItem(IDC_LIST_STEP_MONITOR);
	if (!pList || stepNumber < 1 || stepNumber > 7)
	{
		return;
	}
	
	int nIndex = stepNumber - 1;
	pList->SetItemText(nIndex, 2, status);
	pList->SetItemText(nIndex, 3, time);
	pList->SetItemText(nIndex, 4, note);
	
	// 自动滚动到当前步骤
	pList->EnsureVisible(nIndex, FALSE);
}

void CProcedureDlg::UpdateRealTimeData()
{
	CMFCApplication1Dlg* pMainDlg = GetMainDlg();
	if (!pMainDlg)
	{
		return;
	}
	
	// 更新激光距离（从485串口读取）
	if (pMainDlg->m_serial485.IsOpen())
	{
		// TODO: 实际读取激光距离
		// 暂时显示模拟值
		SetDlgItemText(IDC_STATIC_LASER_DISTANCE, _T("激光距离: 100.0 mm"));
		SetDlgItemText(IDC_STATIC_DISTANCE_ERROR, _T("误差: 0.0 mm"));
	}
	else
	{
		SetDlgItemText(IDC_STATIC_LASER_DISTANCE, _T("激光距离: -- mm"));
		SetDlgItemText(IDC_STATIC_DISTANCE_ERROR, _T("误差: -- mm"));
	}
	
	// 更新机械臂位置
	if (pMainDlg->m_robotArm.IsConnected())
	{
		RobotArmPosition pos = pMainDlg->m_robotArm.GetCurrentPosition();
		CString strPos;
		strPos.Format(_T("机械臂位置: X:%.2f Y:%.2f Z:%.2f Theta:%.2f°"), 
			pos.X, pos.Y, pos.Z, pos.Theta);
		SetDlgItemText(IDC_STATIC_ROBOT_POSITION, strPos);
	}
	else
	{
		SetDlgItemText(IDC_STATIC_ROBOT_POSITION, _T("机械臂位置: X:-- Y:-- Z:-- Theta:--°"));
	}
	
	// 更新视觉坐标
	if (m_params.bEnableVision)
	{
		SetDlgItemText(IDC_STATIC_VISION_COORD, _T("视觉坐标: (模拟系统)"));
	}
	else
	{
		SetDlgItemText(IDC_STATIC_VISION_COORD, _T("视觉坐标: (未启用)"));
	}
}

