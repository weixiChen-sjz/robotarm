// ========== 流程控制按钮响应函数 ==========

void CProcedureDlg::OnBnClickedButtonStartProcedure()
{
	// 从界面读取参数
	ReadParamsFromUI();
	
	// 验证参数
	if (!m_params.Validate())
	{
		MessageBox(_T("参数无效！请检查输入值。"), _T("错误"), MB_OK | MB_ICONERROR);
		return;
	}
	
	// 更新控制器参数
	m_controller.SetParams(m_params);
	
	// 确认启动
	CString strMsg;
	strMsg.Format(
		_T("即将启动穿刺流程，请确认参数：\n\n")
		_T("目标高度: %.1f mm (±%.1f mm)\n")
		_T("精准精度: ±%.1f mm\n")
		_T("穿刺深度: %.1f mm\n")
		_T("消毒时间: %.1f 秒\n")
		_T("安全高度: %.1f mm\n\n")
		_T("确认开始执行？"),
		m_params.fTargetHeight,
		m_params.fCoarseTolerance,
		m_params.fFineTolerance,
		m_params.fPunctureDepth,
		m_params.fDisinfectTime,
		m_params.fSafeHeight
	);
	
	if (MessageBox(strMsg, _T("确认"), MB_YESNO | MB_ICONQUESTION) != IDYES)
	{
		return;
	}
	
	// 启动流程
	if (!m_controller.StartProcedure())
	{
		MessageBox(_T("启动流程失败！\n\n请检查：\n1. 机械臂是否已连接\n2. 串口是否已打开\n3. I/O控制器是否已初始化"),
			_T("错误"), MB_OK | MB_ICONERROR);
		return;
	}
	
	// 记录所有步骤开始时间
	for (int i = 0; i < 7; i++)
	{
		m_dwStepStartTime[i] = 0;
	}
	
	// 记录流程开始时间
	m_dwStepStartTime[0] = GetTickCount();
	
	CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO,
		_T("========== 开始执行穿刺流程 =========="));
}

