// ========== 回调函数 ==========

void CProcedureDlg::OnStateChanged(ProcedureState newState, void* pUserData)
{
	CProcedureDlg* pDlg = (CProcedureDlg*)pUserData;
	if (!pDlg || !pDlg->GetSafeHwnd())
	{
		return;
	}
	
	// 在主线程更新UI
	pDlg->PostMessage(WM_COMMAND, MAKEWPARAM(0, 0), 0);
}

void CProcedureDlg::OnStepChanged(int stepNumber, BOOL bSuccess, void* pUserData)
{
	CProcedureDlg* pDlg = (CProcedureDlg*)pUserData;
	if (!pDlg || !pDlg->GetSafeHwnd())
	{
		return;
	}
	
	// 计算耗时
	DWORD dwElapsed = 0;
	if (stepNumber > 0 && stepNumber <= 7)
	{
		int nIndex = stepNumber - 1;
		if (pDlg->m_dwStepStartTime[nIndex] > 0)
		{
			dwElapsed = GetTickCount() - pDlg->m_dwStepStartTime[nIndex];
		}
		
		// 记录下一步开始时间
		if (stepNumber < 7)
		{
			pDlg->m_dwStepStartTime[stepNumber] = GetTickCount();
		}
	}
	
	// 更新步骤监控
	CString strStatus = bSuccess ? _T("? 完成") : _T("? 失败");
	CString strTime;
	strTime.Format(_T("%.1fs"), dwElapsed / 1000.0f);
	CString strNote = bSuccess ? _T("执行成功") : _T("执行失败");
	
	pDlg->UpdateStepMonitor(stepNumber, strStatus, strTime, strNote);
}
