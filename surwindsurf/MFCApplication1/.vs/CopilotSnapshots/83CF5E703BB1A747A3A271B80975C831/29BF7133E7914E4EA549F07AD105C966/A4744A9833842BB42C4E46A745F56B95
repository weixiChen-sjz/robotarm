		_T("用户手动停止流程"));
}

void CProcedureDlg::OnBnClickedButtonPauseProcedure()
{
	ProcedureState state = m_controller.GetState();
	
	if (state == PROC_STATE_RUNNING)
	{
		m_controller.PauseProcedure();
		CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO, _T("流程已暂停"));
	}
	else if (state == PROC_STATE_PAUSED)
	{
		m_controller.ResumeProcedure();
		CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO, _T("流程已恢复"));
	}
}

