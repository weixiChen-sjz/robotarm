void CProcedureDlg::OnBnClickedButtonStep6Test()
{
	if (m_controller.GetState() == PROC_STATE_RUNNING)
	{
		MessageBox(_T("流程正在运行中，无法单步测试！"), _T("提示"), MB_OK | MB_ICONINFORMATION);
		return;
	}
	
	// ★ 检查冷却时间（5秒）
	DWORD dwCurrentTime = GetTickCount();
	DWORD dwElapsedTime = dwCurrentTime - m_dwStep6LastExecuteTime;
	
	if (m_dwStep6LastExecuteTime > 0 && dwElapsedTime < STEP6_COOLDOWN_MS)
	{
		// 计算剩余冷却时间
		DWORD dwRemainingTime = (STEP6_COOLDOWN_MS - dwElapsedTime) / 1000 + 1;
		
		CString strMsg;
		strMsg.Format(_T("请等待 %d 秒后再次测试步骤6\n\n原因：保护电机，防止连续操作\n\n冷却时间：5秒"), 
			dwRemainingTime);
		
		MessageBox(strMsg, _T("冷却中"), MB_OK | MB_ICONINFORMATION);
		
		// 在步骤监控中显示提示
		CString strNote;
		strNote.Format(_T("冷却中，还需 %d 秒"), dwRemainingTime);
		UpdateStepMonitor(6, _T("○ 等待"), _T("-"), strNote);
		
		return;
	}
	
	// 检查232串口是否打开
	CMFCApplication1Dlg* pMainDlg = GetMainDlg();
	if (!pMainDlg || !pMainDlg->m_serial232.IsOpen())
	{
		// ★ 移除弹窗提示，直接静默失败
		CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_ERROR,
			_T("步骤6测试失败：232串口未打开"));
		UpdateStepMonitor(6, _T("✗ 失败"), _T("-"), _T("232串口未打开"));
		return;
	}
	
	// 从界面读取参数
	ReadParamsFromUI();
	m_controller.SetParams(m_params);
	
	CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO,
		_T("===== 单步测试：步骤6（穿刺执行） ====="));
	
	UpdateStepMonitor(6, _T("⚡ 执行中"), _T("-"), _T("正在测试"));
	
	// ★ 禁用按钮，防止重复点击
	CWnd* pBtn = GetDlgItem(IDC_BUTTON_STEP6_TEST);
	if (pBtn) pBtn->EnableWindow(FALSE);
	
	// ★ 记录开始时间
	DWORD dwStartTime = GetTickCount();
	
	// ★ 使用try-catch保护
	BOOL bResult = FALSE;
	try
	{
		bResult = m_controller.ExecuteStep(6);
	}
	catch (...)
	{
		CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_ERROR,
			_T("步骤6执行时发生异常"));
		bResult = FALSE;
	}
	
	// ★ 计算执行时间
	DWORD dwExecuteTime = GetTickCount() - dwStartTime;
	CString strTime;
	strTime.Format(_T("%.1fs"), dwExecuteTime / 1000.0f);
	
	// ★ 恢复按钮
	if (pBtn) pBtn->EnableWindow(TRUE);
	
	// ★ 记录本次执行完成时间（用于下次冷却检查）
	m_dwStep6LastExecuteTime = GetTickCount();
	
	if (bResult)
	{
		UpdateStepMonitor(6, _T("✓ 成功"), strTime, _T("测试成功"));
		
		// ★ 显示冷却提示
		CString strCooldown;
		strCooldown.Format(_T("测试成功！\n\n下次执行需等待 5 秒冷却时间"));
		CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO,
			_T("步骤6测试成功，进入5秒冷却期"));
	}
	else
	{
		// ★ 无电机时静默显示失败，不弹窗
		UpdateStepMonitor(6, _T("✗ 失败"), strTime, _T("测试失败"));
	}
}

