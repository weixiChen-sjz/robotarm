BOOL CProcedureController::WaitForMotorComplete(int nTimeoutMs)
{
	// TODO: 监听232串口，等待电机完成信号
	// 这里暂时使用延时模拟
	
	DWORD dwStart = GetTickCount();
	while ((GetTickCount() - dwStart) < (DWORD)nTimeoutMs)
	{
		// 检查停止请求
		if (m_bStopRequest)
		{
			return FALSE;
		}
		
		// TODO: 检查232串口是否收到完成信号
		
		Sleep(100);
	}
	
	// 超时
	return FALSE;
}

