}
```

#### **修复后代码** ✅
```cpp
void CProcedureDlg::OnBnClickedButtonStep6Test()
{
    // 检查流程状态
    if (m_controller.GetState() == PROC_STATE_RUNNING)
    {
        MessageBox(_T("流程正在运行中，无法单步测试！"), _T("提示"), MB_OK | MB_ICONINFORMATION);
        return;
    }
    
    // ★ 检查232串口是否打开（静默失败，不弹窗）
    CMFCApplication1Dlg* pMainDlg = GetMainDlg();
    if (!pMainDlg || !pMainDlg->m_serial232.IsOpen())
    {
        CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_ERROR,
            _T("步骤6测试失败：232串口未打开"));
        UpdateStepMonitor(6, _T("✗ 失败"), _T("-"), _T("232串口未打开"));
        return;
    }
    
    // 从界面读取参数
    ReadParamsFromUI();
    m_controller.SetParams(m_params);
    
    CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_INFO,
        _T("===== 单步测试：步骤6（穿刺执行） ====="));
    
    UpdateStepMonitor(6, _T("⚡ 执行中"), _T("-"), _T("正在测试"));
    
    // ★ 禁用按钮，防止重复点击
    CWnd* pBtn = GetDlgItem(IDC_BUTTON_STEP6_TEST);
    if (pBtn) pBtn->EnableWindow(FALSE);
    
    // ★ 使用try-catch保护
    BOOL bResult = FALSE;
    try
    {
        bResult = m_controller.ExecuteStep(6);
    }
    catch (...)
    {
        CLogManager::GetInstance().AddLog(_T("流程控制"), LOG_ERROR,
            _T("步骤6执行时发生异常"));
        bResult = FALSE;
    }
    
    // ★ 恢复按钮
    if (pBtn) pBtn->EnableWindow(TRUE);
    
    if (bResult)
    {
        UpdateStepMonitor(6, _T("✓ 成功"), _T("3.0s"), _T("测试成功"));
    }
    else
    {
        // ★ 无电机时静默显示失败，不弹窗
        UpdateStepMonitor(6, _T("✗ 失败"), _T("-"), _T("测试失败"));
    }
}
```

