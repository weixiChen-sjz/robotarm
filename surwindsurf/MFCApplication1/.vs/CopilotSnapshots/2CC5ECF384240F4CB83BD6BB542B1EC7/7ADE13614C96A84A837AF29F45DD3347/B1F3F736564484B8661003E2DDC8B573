#pragma once
#include "ProcedureParams.h"
#include "IVisionSystem.h"
#include "IRobotArmController.h"
#include "SerialPort.h"
#include "IOController.h"

class IIOController
{
public:
	virtual ~IIOController() = default;
	virtual BOOL Initialize() = 0;
	virtual void ProcessGPIO() = 0;
	virtual void Shutdown() = 0;
	virtual BOOL IsOpen() const = 0;
	virtual BYTE GetGPIOLevels() = 0;
	virtual BOOL OpenInfusionSwitch() = 0;
	virtual BOOL CloseInfusionSwitch() = 0;
	virtual BOOL OpenDisinfectSwitch() = 0;
	virtual BOOL CloseDisinfectSwitch() = 0;
	virtual BOOL OpenLaserSwitch() = 0;
	virtual BOOL CloseLaserSwitch() = 0;
	virtual BOOL GetInfusionSensorState() = 0;
	virtual BOOL GetDisinfectSensorState() = 0;
	virtual BOOL GetLaserSensorState() = 0;
	virtual BOOL GetInfusionSwitchState() const = 0;
	virtual BOOL GetDisinfectSwitchState() const = 0;
	virtual BOOL GetLaserSwitchState() const = 0;
	virtual CString GetHardwareStateText() const = 0;
};

class CIOControllerAdapter : public IIOController
{
public:
	explicit CIOControllerAdapter(CIOController* impl) : m_impl(impl) {}
	BOOL Initialize() override { return m_impl ? m_impl->Initialize() : FALSE; }
	void ProcessGPIO() override { if (m_impl) m_impl->ProcessGPIO(); }
	void Shutdown() override { if (m_impl) m_impl->Shutdown(); }
	BOOL IsOpen() const override { return m_impl ? m_impl->IsOpen() : FALSE; }
	BYTE GetGPIOLevels() override { return m_impl ? m_impl->GetGPIOLevels() : 0; }
	BOOL OpenInfusionSwitch() override { return m_impl ? m_impl->OpenInfusionSwitch() : FALSE; }
	BOOL CloseInfusionSwitch() override { return m_impl ? m_impl->CloseInfusionSwitch() : FALSE; }
	BOOL OpenDisinfectSwitch() override { return m_impl ? m_impl->OpenDisinfectSwitch() : FALSE; }
	BOOL CloseDisinfectSwitch() override { return m_impl ? m_impl->CloseDisinfectSwitch() : FALSE; }
	BOOL OpenLaserSwitch() override { return m_impl ? m_impl->OpenLaserSwitch() : FALSE; }
	BOOL CloseLaserSwitch() override { return m_impl ? m_impl->CloseLaserSwitch() : FALSE; }
	BOOL GetInfusionSensorState() override { return m_impl ? m_impl->GetInfusionSensorState() : FALSE; }
	BOOL GetDisinfectSensorState() override { return m_impl ? m_impl->GetDisinfectSensorState() : FALSE; }
	BOOL GetLaserSensorState() override { return m_impl ? m_impl->GetLaserSensorState() : FALSE; }
	BOOL GetInfusionSwitchState() const override { return m_impl ? m_impl->GetInfusionSwitchState() : FALSE; }
	BOOL GetDisinfectSwitchState() const override { return m_impl ? m_impl->GetDisinfectSwitchState() : FALSE; }
	BOOL GetLaserSwitchState() const override { return m_impl ? m_impl->GetLaserSwitchState() : FALSE; }
	CString GetHardwareStateText() const override { return m_impl ? m_impl->GetHardwareStateText() : CString(_T("未连接")); }

private:
	CIOController* m_impl;
};

// 流程状态枚举
enum ProcedureState
{
	PROC_STATE_IDLE,         // 空闲
	PROC_STATE_RUNNING,      // 运行中
	PROC_STATE_PAUSED,       // 暂停
	PROC_STATE_STOPPED,      // 已停止
	PROC_STATE_COMPLETED,    // 完成
	PROC_STATE_ERROR         // 错误
};

// 流程错误码（用于UI精确提示失败原因）
enum ProcedureErrorCode
{
	PROC_ERR_NONE = 0,
	PROC_ERR_INVALID_PARAMS,
	PROC_ERR_HARDWARE_NOT_READY,
	PROC_ERR_ROBOT_NOT_CONNECTED,
	PROC_ERR_IO_NOT_INITIALIZED,
	PROC_ERR_SERIAL232_NOT_OPEN,
	PROC_ERR_SERIAL485_NOT_OPEN,
	PROC_ERR_LASER_READ_FAILED,
	PROC_ERR_VISION_NOT_CONNECTED,
	PROC_ERR_VISION_NOT_CALIBRATED,
	PROC_ERR_VISION_DETECT_FAILED,
	PROC_ERR_ROBOT_MOVE_FAILED,
	PROC_ERR_TIMEOUT,
	PROC_ERR_STOP_REQUESTED,
	PROC_ERR_UNKNOWN
};

// 流程控制器
// 负责管理7步穿刺流程的执行
class CProcedureController
{
public:
	CProcedureController();
	~CProcedureController();
	
	// ========== 初始化 ==========
	// 设置硬件设备接口
	void SetRobotArm(IRobotArmController* pRobotArm);
	void SetSerial232(CSerialPort* pSerial232);
	void SetSerial485(CSerialPort* pSerial485);
	void SetIOController(IIOController* pIOController);
	
	// 设置视觉系统接口（可选，预留）
	void SetVisionSystem(IVisionSystem* pVision, BOOL bOwn = FALSE);
	
	// 设置流程参数
	void SetParams(const ProcedureParams& params);
	const ProcedureParams& GetParams() const { return m_params; }
	
	// ========== 流程控制 ==========
	// 启动完整流程（7步）
	BOOL StartProcedure();
	
	// 停止流程
	void StopProcedure();
	
	// 暂停流程
	void PauseProcedure();
	
	// 恢复流程
	void ResumeProcedure();
	
	// 紧急停止（立即停止所有设备）
	void EmergencyStop();
	
	// ========== 单步执行（用于调试）==========
	BOOL ExecuteStep(int stepNumber);
	
	// ========== 状态查询 ==========
	ProcedureState GetState() const { return m_state; }
	int GetCurrentStep() const { return m_nCurrentStep; }
	float GetProgress() const;  // 返回 0~100

	// 最后错误信息（线程安全只读）
	ProcedureErrorCode GetLastErrorCode() const;
	CString GetLastErrorMessage() const;
	void ClearLastError();

	// Step4 XY闭环误差（供UI查询）
	void GetLastXYError(int& dxPx, int& dyPx, float& dxMm, float& dyMm) const;
	
	// 读取激光测距仪距离（485，供UI/流程复用；失败返回-1.0f）
	float GetLaserDistance();

	// 运行期缓存（供UI只读显示，避免与流程线程争用硬件）
	BOOL GetLastLaserReading(float& distanceMm, float& errorMm) const;
	BOOL GetLastRobotPosition(RobotArmPosition& pos) const;
	
	// 获取步骤名称
	CString GetStepName(int stepNumber) const;
	
	// ========== 回调通知 ==========
	// 设置状态变化回调函数
	typedef void (*StateChangeCallback)(ProcedureState newState, void* pUserData);
	void SetStateChangeCallback(StateChangeCallback callback, void* pUserData);
	
	// 设置步骤变化回调函数
	typedef void (*StepChangeCallback)(int stepNumber, BOOL bSuccess, void* pUserData);
	void SetStepChangeCallback(StepChangeCallback callback, void* pUserData);
	
private:
	// ========== 7步流程实现 ==========
	BOOL ExecuteStep1_VisionLocate();          // 步骤1：视觉定位
	BOOL ExecuteStep2_LaserCoarseAdjust();     // 步骤2：激光粗调
	BOOL ExecuteStep3_DetectPuncturePoint();   // 步骤3：识别穿刺点
	BOOL ExecuteStep4_PreciseAlignment();      // 步骤4：精准对位
	BOOL ExecuteStep5_Disinfection();          // 步骤5：消毒准备
	BOOL ExecuteStep6_Puncture();              // 步骤6：穿刺执行
	BOOL ExecuteStep7_Infusion();              // 步骤7：输液启动
	
	// ========== 辅助函数 ==========
	// 获取激光测距仪距离

	// Step4：XY闭环（IR像素闭环）
	BOOL ExecuteStep4_XYAlign();
	
	// 等待电机完成（步骤6）
	BOOL WaitForMotorComplete(int nTimeoutMs);
	
	// 使用手动位置（视觉系统未启用时）
	BOOL UseManualPosition();
	
	// 检查硬件状态
	BOOL CheckHardwareReady();
	
	// 异常回滚（关闭所有开关，停止机械臂）
	void Rollback();
	
	// 日志输出
	void LogInfo(LPCTSTR format, ...);
	void LogWarning(LPCTSTR format, ...);
	void LogError(LPCTSTR format, ...);
	
	// 状态变化通知
	void NotifyStateChange(ProcedureState newState);
	void NotifyStepChange(int stepNumber, BOOL bSuccess);
	
	// ========== 线程相关 ==========
	// 流程执行线程
	static UINT __stdcall ThreadFunc(LPVOID pParam);
	void ThreadProcedure();
	
	HANDLE m_hThread;           // 线程句柄
	BOOL m_bThreadRunning;      // 线程运行标志
	BOOL m_bStopRequest;        // 停止请求标志
	BOOL m_bPauseRequest;       // 暂停请求标志
	
	// ========== 成员变量 ==========
	// 硬件设备接口
	IRobotArmController* m_pRobotArm;
	CSerialPort* m_pSerial232;
	CSerialPort* m_pSerial485;
	IIOController* m_pIOController;
	
	// 视觉系统接口（可选）
	IVisionSystem* m_pVision;
	BOOL m_bOwnVision;  // 标记是否需要释放视觉系统
	
	// 流程参数
	ProcedureParams m_params;
	
	// 流程状态
	ProcedureState m_state;
	int m_nCurrentStep;        // 当前执行步骤（1~7）
	
	// 穿刺点位置（步骤3识别后保存）
	RobotArmPosition m_puncturePoint;

	// Step4：XY对位状态（用于UI实时显示/调试）
	int m_lastDxPx;
	int m_lastDyPx;
	float m_lastDxMm;
	float m_lastDyMm;

	// 运行期缓存（UI只读）
	BOOL m_bLastLaserValid;
	float m_lastLaserDistanceMm;
	float m_lastLaserErrorMm;
	BOOL m_bLastRobotPosValid;
	RobotArmPosition m_lastRobotPos;
	
	// 回调函数
	StateChangeCallback m_stateCallback;
	void* m_stateCallbackUserData;
	StepChangeCallback m_stepCallback;
	void* m_stepCallbackUserData;
	
	// 线程同步
	CRITICAL_SECTION m_cs;     // 临界区

	// 最后错误信息
	ProcedureErrorCode m_lastErrorCode;
	CString m_lastErrorMessage;

	// 设置最后错误（内部使用）
	void SetLastError(ProcedureErrorCode code, const CString& message);
};
