BOOL CIOControllerProxy::GetInfusionSwitchState()
{
	IOBridge::SwitchStates st{};
	DWORD got = 0;
	if (SendCommand((uint32_t)IOBridge::Command::GetSwitchStates, nullptr, 0, &st, sizeof(st), &got) && got >= sizeof(st))
		m_lastInfusionOpen = st.infusionOpen ? TRUE : FALSE;
	return m_lastInfusionOpen;
}

