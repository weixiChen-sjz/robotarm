BOOL CIOControllerProxy::CloseLaserSwitch() { return SendCommand((uint32_t)IOBridge::Command::CloseLaserSwitch, nullptr, 0, nullptr, 0, nullptr); }

BOOL CIOControllerProxy::GetInfusionSensorState()
{
	uint8_t v = 0;
	DWORD got = 0;
	return SendCommand((uint32_t)IOBridge::Command::GetInfusionSensorState, nullptr, 0, &v, sizeof(v), &got) && got >= 1 ? (v != 0) : FALSE;
}

