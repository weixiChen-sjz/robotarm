CProcedureController::CProcedureController()
{
	// 初始化硬件接口为空
	m_pRobotArm = nullptr;
	m_pSerial232 = nullptr;
	m_pSerial485 = nullptr;
	m_pIOController = nullptr;
	m_pVision = nullptr;
	m_bOwnVision = FALSE;  // ★ 新增：初始化所有权标志
	
	// 初始化状态
	m_state = PROC_STATE_IDLE;
	m_nCurrentStep = 0;
	
	// 初始化穿刺点
	m_puncturePoint.X = 0;
	m_puncturePoint.Y = 0;
	m_puncturePoint.Z = 0;

	// 初始化XY对位状态
	m_lastDxPx = 0;
	m_lastDyPx = 0;
	m_lastDxMm = 0.0f;
	m_lastDyMm = 0.0f;

	// 初始化运行期缓存
	m_bLastLaserValid = FALSE;
	m_lastLaserDistanceMm = -1.0f;
	m_lastLaserErrorMm = 0.0f;
	m_bLastRobotPosValid = FALSE;
	memset(&m_lastRobotPos, 0, sizeof(m_lastRobotPos));
	
	// 初始化回调函数
	m_stateCallback = nullptr;
	m_stateCallbackUserData = nullptr;
	m_stepCallback = nullptr;
	m_stepCallbackUserData = nullptr;
	
	// 初始化线程相关
	m_hThread = NULL;
	m_bThreadRunning = FALSE;
	m_bStopRequest = FALSE;
	m_bPauseRequest = FALSE;

	// 初始化最后错误
	m_lastErrorCode = PROC_ERR_NONE;
	m_lastErrorMessage.Empty();
	
	// 初始化临界区
	InitializeCriticalSection(&m_cs);
}

ProcedureErrorCode CProcedureController::GetLastErrorCode() const
{
	EnterCriticalSection((LPCRITICAL_SECTION)&m_cs);
	ProcedureErrorCode code = m_lastErrorCode;
	LeaveCriticalSection((LPCRITICAL_SECTION)&m_cs);
	return code;
}

CString CProcedureController::GetLastErrorMessage() const
{
	EnterCriticalSection((LPCRITICAL_SECTION)&m_cs);
	CString msg = m_lastErrorMessage;
	LeaveCriticalSection((LPCRITICAL_SECTION)&m_cs);
	return msg;
}

void CProcedureController::ClearLastError()
{
	EnterCriticalSection(&m_cs);
	m_lastErrorCode = PROC_ERR_NONE;
	m_lastErrorMessage.Empty();
	LeaveCriticalSection(&m_cs);
}

void CProcedureController::SetLastError(ProcedureErrorCode code, const CString& message)
{
	EnterCriticalSection(&m_cs);
	m_lastErrorCode = code;
	m_lastErrorMessage = message;
	LeaveCriticalSection(&m_cs);
}

CProcedureController::~CProcedureController()
{
	// 停止线程
	if (m_hThread)
	{
		m_bStopRequest = TRUE;
		
		// ★ 改进：检查等待结果
		DWORD dwRet = WaitForSingleObject(m_hThread, 5000);
		if (dwRet == WAIT_TIMEOUT)
		{
			LogWarning(_T("流程线程5秒内未退出，强制终止"));
			TerminateThread(m_hThread, 1);
		}
		
		CloseHandle(m_hThread);
		m_hThread = NULL;
	}
	
	// ★ 新增：释放视觉系统
	if (m_bOwnVision && m_pVision)
	{
		delete m_pVision;
		m_pVision = nullptr;
	}
	
	// 删除临界区
	DeleteCriticalSection(&m_cs);
}

