// ========== 流程控制 ==========

BOOL CProcedureController::StartProcedure()
{
	ClearLastError();
	// 检查是否已在运行
	if (m_state == PROC_STATE_RUNNING)
	{
		LogWarning(_T("流程已在运行中"));
		return FALSE;
	}
	
	// 检查硬件准备状态
	if (!CheckHardwareReady())
	{
		SetLastError(PROC_ERR_HARDWARE_NOT_READY, _T("硬件未就绪"));
		LogError(_T("硬件未就绪，无法启动流程"));
		return FALSE;
	}
	
	// 验证参数
	if (!m_params.Validate())
	{
		SetLastError(PROC_ERR_INVALID_PARAMS, _T("流程参数无效"));
		LogError(_T("流程参数无效"));
		return FALSE;
	}
	
	// 停止旧线程（如果存在）
	if (m_hThread)
	{
		m_bStopRequest = TRUE;
		WaitForSingleObject(m_hThread, 3000);
		CloseHandle(m_hThread);
		m_hThread = NULL;
	}
	
	// 重置状态
	m_bStopRequest = FALSE;
	m_bPauseRequest = FALSE;
	m_nCurrentStep = 0;
	
	// 启动线程执行流程
	m_hThread = (HANDLE)_beginthreadex(NULL, 0, ThreadFunc, this, 0, NULL);
	if (!m_hThread)
	{
		LogError(_T("启动流程线程失败"));
		return FALSE;
	}
	
	NotifyStateChange(PROC_STATE_RUNNING);
	LogInfo(_T("========== 开始执行穿刺流程 =========="));
	
	return TRUE;
}

void CProcedureController::StopProcedure()
{
	if (m_state != PROC_STATE_RUNNING && m_state != PROC_STATE_PAUSED)
	{
		return;
	}
	
	LogWarning(_T("用户手动停止流程"));
	m_bStopRequest = TRUE;
	m_bPauseRequest = FALSE;  // 取消暂停
	
	// 等待线程结束
	if (m_hThread)
	{
		WaitForSingleObject(m_hThread, 3000);
	}
	
	NotifyStateChange(PROC_STATE_STOPPED);
}

void CProcedureController::PauseProcedure()
{
	if (m_state != PROC_STATE_RUNNING)
	{
		return;
	}
	
	LogInfo(_T("流程已暂停"));
	m_bPauseRequest = TRUE;
	NotifyStateChange(PROC_STATE_PAUSED);
}

void CProcedureController::ResumeProcedure()
{
	if (m_state != PROC_STATE_PAUSED)
	{
		return;
	}
	
	LogInfo(_T("流程已恢复"));
	m_bPauseRequest = FALSE;
	NotifyStateChange(PROC_STATE_RUNNING);
}

void CProcedureController::EmergencyStop()
{
	LogError(_T("!!! 紧急停止 !!!"));
	
	// 立即停止所有设备
	if (m_pRobotArm && m_pRobotArm->IsConnected())
	{
		m_pRobotArm->EmergencyStop();
	}
	
	if (m_pIOController && m_pIOController->IsInitialized())
	{
		m_pIOController->CloseInfusionSwitch();
		m_pIOController->CloseDisinfectSwitch();
		m_pIOController->CloseLaserSwitch();
	}
	
	// 停止线程
	m_bStopRequest = TRUE;
	
	NotifyStateChange(PROC_STATE_ERROR);
}

// ========== 单步执行 ==========

BOOL CProcedureController::ExecuteStep(int stepNumber)
{
	if (m_state == PROC_STATE_RUNNING)
	{
		LogWarning(_T("流程运行中，无法单步执行"));
		return FALSE;
	}
	
	if (stepNumber < 1 || stepNumber > 7)
	{
		LogError(_T("步骤编号无效：%d"), stepNumber);
		return FALSE;
	}
	
	LogInfo(_T("===== 单步执行：步骤%d ====="), stepNumber);
	
	BOOL bResult = FALSE;
	switch (stepNumber)
	{
	case 1: bResult = ExecuteStep1_VisionLocate(); break;
	case 2: bResult = ExecuteStep2_LaserCoarseAdjust(); break;
	case 3: bResult = ExecuteStep3_DetectPuncturePoint(); break;
	case 4: bResult = ExecuteStep4_PreciseAlignment(); break;
	case 5: bResult = ExecuteStep5_Disinfection(); break;
	case 6: bResult = ExecuteStep6_Puncture(); break;
	case 7: bResult = ExecuteStep7_Infusion(); break;
	}
	
	if (bResult)
	{
		LogInfo(_T("步骤%d 执行成功"), stepNumber);
	}
	else
	{
		LogError(_T("步骤%d 执行失败"), stepNumber);
	}
	
	NotifyStepChange(stepNumber, bResult);
	
	return bResult;
}

// ========== 状态查询 ==========

float CProcedureController::GetProgress() const
{
	if (m_nCurrentStep == 0)
	{
		return 0.0f;
	}
	
	// 计算进度（0~100）
	return (m_nCurrentStep * 100.0f) / 7.0f;
}

CString CProcedureController::GetStepName(int stepNumber) const
{
	switch (stepNumber)
	{
	case 1: return _T("视觉定位（YOLO识别硅胶模型）");
	case 2: return _T("激光粗调（调整高度±2mm）");
	case 3: return _T("识别穿刺点+调整姿态");
	case 4: return _T("精准对位（激光点重合±0.2mm）");
	case 5: return _T("喷消毒液（2秒）");
	case 6: return _T("穿刺执行（电机运动）");
	case 7: return _T("输液启动（打开输液阀）");
