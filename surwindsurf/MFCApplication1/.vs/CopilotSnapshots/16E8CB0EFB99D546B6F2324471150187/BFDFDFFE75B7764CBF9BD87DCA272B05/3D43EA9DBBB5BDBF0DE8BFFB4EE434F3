// ========== 辅助函数 ==========

float CProcedureController::GetLaserDistance()
{
	// 从485串口读取激光测距数据
	if (!m_pSerial485 || !m_pSerial485->IsOpen())
	{
		SetLastError(PROC_ERR_SERIAL485_NOT_OPEN, _T("485串口未打开"));
		return -1.0f;  // 无效值
	}

	// 发送指令前清空缓冲，减少读到历史残留/粘包的概率
	m_pSerial485->ClearBuffer();
	
	// ★ 【关键修复】发送测距指令
	// 指令格式：01 04 00 18 00 02 F1 CC
	// 01 - 设备地址
	// 04 - 功能码（读输入寄存器）
	// 00 18 - 起始地址（0x0018）
	// 00 02 - 读取长度（2个寄存器，共4字节浮点数）
	// F1 CC - CRC校验码
	BYTE cmdBuffer[] = { 0x01, 0x04, 0x00, 0x18, 0x00, 0x02, 0xF1, 0xCC };
	
	if (!m_pSerial485->SendData((char*)cmdBuffer, sizeof(cmdBuffer), FALSE))
	{
		SetLastError(PROC_ERR_LASER_READ_FAILED, _T("发送激光测距指令失败"));
		LogWarning(_T("发送激光测距指令失败"));
		return -1.0f;
	}
	
	// ★ 等待激光测距仪响应（建议100-150ms）
	Sleep(120);

	// 读取串口数据（考虑分包/粘包，做拼包与帧头同步）
	BYTE rx[512];
	DWORD total = 0;
	const DWORD MAX_READ_LOOPS = 6;
	const DWORD WANT_MIN = 9; // 01 04 04 + float(4) + crc(2)
	for (DWORD loop = 0; loop < MAX_READ_LOOPS; ++loop)
	{
		char chunk[256];
		DWORD dwBytesRead = 0;
		if (!m_pSerial485->ReceiveData(chunk, sizeof(chunk), dwBytesRead))
		{
			Sleep(30);
			continue;
		}

		if (dwBytesRead == 0)
		{
			Sleep(30);
			continue;
		}

		DWORD copy = (DWORD)min((DWORD)dwBytesRead, (DWORD)(sizeof(rx) - total));
		memcpy(rx + total, chunk, copy);
		total += copy;

		if (total < WANT_MIN)
		{
			Sleep(30);
			continue;
		}

		// 在缓冲里寻找帧头 01 04 04
		for (DWORD start = 0; start + WANT_MIN <= total; ++start)
		{
			if (rx[start] == 0x01 && rx[start + 1] == 0x04 && rx[start + 2] == 0x04)
			{
				float fDistance = 0.0f;
				if (CSerialPort::ParseLaserDistance((const char*)(rx + start), total - start, fDistance))
				{
					// ★ 验证真实距离范围
					// ParseLaserDistance() 已经换算为真实距离（200mm - 偏移值）
					// 激光测距仪硬件有效范围：120-280mm
					// 
					// 示例：
					// 偏移值 0mm   → 真实距离 = 200 - 0   = 200mm ✓
					// 偏移值 48mm  → 真实距离 = 200 - 48  = 152mm ✓
					// 偏移值 80mm  → 真实距离 = 200 - 80  = 120mm ✓
					// 偏移值 -80mm → 真实距离 = 200 - (-80) = 280mm ✓
					if (fDistance >= 120.0f && fDistance <= 280.0f)
					{
							EnterCriticalSection(&m_cs);
							m_bLastLaserValid = TRUE;
							m_lastLaserDistanceMm = fDistance;
							m_lastLaserErrorMm = fDistance - m_params.fTargetHeight;
							LeaveCriticalSection(&m_cs);
						return fDistance;  // 返回真实距离
					}
					LogWarning(_T("激光距离超出有效范围: %.2f mm (有效范围: 120-280mm)"), fDistance);
				}
			}
		}

		Sleep(30);
	}
	
	// 如果多次读取失败，返回错误值（不使用模拟值）
	SetLastError(PROC_ERR_LASER_READ_FAILED, _T("无法读取激光距离"));
	LogError(_T("无法读取激光距离：连续3次读取失败，请检查485串口和激光测距仪"));
	EnterCriticalSection(&m_cs);
	m_bLastLaserValid = FALSE;
	m_lastLaserDistanceMm = -1.0f;
	m_lastLaserErrorMm = 0.0f;
	LeaveCriticalSection(&m_cs);
	return -1.0f;  // 明确的错误值
}

BOOL CProcedureController::WaitForMotorComplete(int nTimeoutMs)
{
	// ★ 修复：电机不会返回任何信号，改为简单的超时等待
	// 假设电机在指定时间内能够完成动作
	
	if (!m_pSerial232 || !m_pSerial232->IsOpen())
	{
		LogError(_T("232串口未打开"));
		return FALSE;
	}
	
	LogInfo(_T("等待电机完成动作（预估时间: %d毫秒）..."), nTimeoutMs);
	LogInfo(_T("注意：电机不返回完成信号，采用超时等待方式"));
	
	// 使用GetTickCount64()计时
	ULONGLONG dwStart = GetTickCount64();
	
	// 分段等待，以便响应停止请求
	const int STEP_MS = 200;  // 每200ms检查一次停止请求
	
	while ((GetTickCount64() - dwStart) < (ULONGLONG)nTimeoutMs)
	{
		// 检查停止请求
		if (m_bStopRequest)
		{
			LogWarning(_T("收到停止请求，中断等待"));
			return FALSE;
		}
		
		// 检查暂停请求
		while (m_bPauseRequest)
		{
			Sleep(100);
			if (m_bStopRequest)
			{
				LogWarning(_T("暂停期间收到停止请求"));
				return FALSE;
			}
		}
		
		Sleep(STEP_MS);
	}
	
	// 超时时间到，假设电机已完成
	LogInfo(_T("电机动作等待完成（已等待 %d 毫秒，未等待回包）"), nTimeoutMs);
	return TRUE;
}

BOOL CProcedureController::UseManualPosition()
{
	// 视觉系统未启用，使用手动设定的预设位置或当前位置
	LogWarning(_T("视觉系统未启用，使用预设坐标"));
	
	if (!m_pRobotArm || !m_pRobotArm->IsConnected())
	{
		LogError(_T("机械臂未连接"));
		return FALSE;
	}
	
	// 使用当前位置
	RobotArmPosition currentPos = m_pRobotArm->GetCurrentPosition();
	
	LogInfo(_T("使用当前位置作为目标: (%.2f, %.2f, %.2f) mm"), 
		currentPos.X, currentPos.Y, currentPos.Z);
	
	// 也可以使用预设坐标（如果有配置）
	// RobotArmPosition presetPos(300.0f, 200.0f, 100.0f);
	// return m_pRobotArm->MoveTo(presetPos, 50);
	
	return TRUE;  // 保持当前位置
}

BOOL CProcedureController::CheckHardwareReady()
{
	LogInfo(_T("检查硬件设备状态..."));
	
	// 检查机械臂
	if (!m_pRobotArm || !m_pRobotArm->IsConnected())
	{
		LogError(_T("机械臂未连接"));
		return FALSE;
	}
	
	// 检查232串口（电机）
	if (!m_pSerial232 || !m_pSerial232->IsOpen())
	{
		LogError(_T("232串口未打开（电机控制）"));
		return FALSE;
	}
	
	// 检查485串口（激光测距仪）
	if (!m_pSerial485 || !m_pSerial485->IsOpen())
	{
		LogError(_T("485串口未打开（激光测距）"));
		return FALSE;
	}
	
	// 检查I/O控制器
	if (!m_pIOController || !m_pIOController->IsInitialized())
	{
		SetLastError(PROC_ERR_IO_NOT_INITIALIZED, _T("I/O控制器未初始化"));
		LogError(_T("I/O控制器未初始化"));
		return FALSE;
	}
	
	// 检查I/O硬件连接
	if (!m_pIOController->IsHardwareConnected())
	{
		LogWarning(_T("I/O硬件未连接，某些功能可能无法使用"));
	}
	
	// 视觉系统是可选的
	if (m_params.bEnableVision)
	{
		if (!m_pVision || !m_pVision->IsConnected())
		{
			LogWarning(_T("视觉系统已启用但未连接，将使用预设坐标"));
		}
		else if (!m_pVision->IsCalibrated())
		{
			LogWarning(_T("视觉系统未标定，坐标转换可能不准确"));
		}
	}
	
	LogInfo(_T("硬件设备检查完成"));
	return TRUE;
}

void CProcedureController::Rollback()
{
	LogWarning(_T("执行异常回滚..."));
	
	// 关闭所有I/O开关
	if (m_pIOController && m_pIOController->IsInitialized())
	{
		m_pIOController->CloseInfusionSwitch();
		m_pIOController->CloseDisinfectSwitch();
		m_pIOController->CloseLaserSwitch();
		
		LogInfo(_T("所有I/O开关已关闭"));
	}
	
	// 停止机械臂
	if (m_pRobotArm && m_pRobotArm->IsConnected())
	{
		m_pRobotArm->Stop();
		LogInfo(_T("机械臂已停止"));
	}
	
	LogInfo(_T("回滚完成"));
}

