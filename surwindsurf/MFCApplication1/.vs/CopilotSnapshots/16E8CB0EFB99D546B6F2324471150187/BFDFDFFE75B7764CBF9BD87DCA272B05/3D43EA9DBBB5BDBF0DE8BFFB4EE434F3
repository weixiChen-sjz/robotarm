// ========== 状态通知 ==========

void CProcedureController::NotifyStateChange(ProcedureState newState)
{
	EnterCriticalSection(&m_cs);
	m_state = newState;
	LeaveCriticalSection(&m_cs);
	
	if (m_stateCallback)
	{
		m_stateCallback(newState, m_stateCallbackUserData);
	}
}

void CProcedureController::NotifyStepChange(int stepNumber, BOOL bSuccess)
{
	if (m_stepCallback)
	{
		m_stepCallback(stepNumber, bSuccess, m_stepCallbackUserData);
	}
}

// ========== 线程函数 ==========

UINT __stdcall CProcedureController::ThreadFunc(LPVOID pParam)
{
	CProcedureController* pThis = (CProcedureController*)pParam;
	pThis->ThreadProcedure();
	return 0;
}

void CProcedureController::ThreadProcedure()
{
	m_bThreadRunning = TRUE;
	
	// 执行7步流程
	for (int step = 1; step <= 7; step++)
	{
		// 检查停止请求
		if (m_bStopRequest)
		{
			LogWarning(_T("流程已停止"));
			Rollback();
			NotifyStateChange(PROC_STATE_STOPPED);
			m_bThreadRunning = FALSE;
			return;
		}
		
		// 检查暂停请求
		while (m_bPauseRequest)
		{
			Sleep(100);
			
			// 暂停期间也要检查停止请求
			if (m_bStopRequest)
			{
				LogWarning(_T("流程已停止（从暂停恢复）"));
				Rollback();
				NotifyStateChange(PROC_STATE_STOPPED);
				m_bThreadRunning = FALSE;
				return;
			}
		}
		
		// 更新当前步骤
		m_nCurrentStep = step;
		LogInfo(_T("开始执行步骤%d：%s"), step, GetStepName(step));
		
		// 执行当前步骤
		BOOL bSuccess = ExecuteStep(step);
		
		// 检查执行结果
		if (!bSuccess)
		{
			LogError(_T("步骤%d执行失败，流程中止"), step);
			Rollback();
			NotifyStateChange(PROC_STATE_ERROR);
			m_bThreadRunning = FALSE;
			return;
		}
		
		// 短暂延时
		Sleep(200);
	}
	
	// 全部成功
	LogInfo(_T("========== 流程执行完成 =========="));
	NotifyStateChange(PROC_STATE_COMPLETED);
	m_bThreadRunning = FALSE;
}

// ========== 7步流程实现 ==========

BOOL CProcedureController::ExecuteStep1_VisionLocate()
{
	LogInfo(_T("【步骤1】视觉定位（粗定位）"));
	
	// 1. 检查视觉系统
	if (!m_pVision || !m_pVision->IsConnected())
	{
		// 未启用视觉 → 使用预设坐标或当前位置
		LogWarning(_T("视觉系统未启用，使用当前位置"));
		return UseManualPosition();
	}
	
	// 2. 检查视觉系统是否已标定
	if (!m_pVision->IsCalibrated())
	{
		LogError(_T("视觉系统未标定，无法进行坐标转换"));
		return FALSE;
	}
	
	// 3. 识别模型目标（硅胶模型）
	float camX, camY, camZ;
	LogInfo(_T("开始识别目标模型..."));
	
	if (!m_pVision->DetectModel(camX, camY, camZ))
	{
		LogError(_T("视觉识别失败：未检测到目标模型"));
		return FALSE;
	}
	
	LogInfo(_T("目标识别成功 - 相机坐标: (%.2f, %.2f, %.2f) mm"), camX, camY, camZ);
	
	// 4. 坐标转换（相机坐标系 → 机械臂坐标系）
	float robotX, robotY, robotZ;
	m_pVision->TransformCoordinate(camX, camY, camZ, 
	                               robotX, robotY, robotZ);
	
	LogInfo(_T("坐标转换完成 - 机械臂坐标: (%.2f, %.2f, %.2f) mm"), robotX, robotY, robotZ);
	
	// 5. 移动到目标上方（安全高度）
	if (!m_pRobotArm || !m_pRobotArm->IsConnected())
	{
		LogError(_T("机械臂未连接"));
		return FALSE;
	}
	
	RobotArmPosition targetPos;
	targetPos.X = robotX;
	targetPos.Y = robotY;
	targetPos.Z = robotZ + m_params.fSafeHeight;  // 加上安全高度
	
	LogInfo(_T("移动到目标上方（安全高度）: (%.2f, %.2f, %.2f) mm"), 
		targetPos.X, targetPos.Y, targetPos.Z);
	
	// 以50%速度移动
	if (!m_pRobotArm->MoveTo(targetPos, 50))
	{
		LogError(_T("机械臂移动失败"));
		return FALSE;
	}
	
	// 等待移动完成
	Sleep(1000);
	
	LogInfo(_T("【步骤1】完成 - 已到达目标上方"));
	return TRUE;
}

BOOL CProcedureController::ExecuteStep2_LaserCoarseAdjust()
{
	LogInfo(_T("【步骤2】激光粗调高度"));
	
	// 1. 打开激光测距仪
	if (!m_pIOController || !m_pIOController->IsInitialized())
	{
		LogError(_T("I/O控制器未初始化"));
		return FALSE;
	}
	
	LogInfo(_T("打开激光测距仪..."));
	if (!m_pIOController->OpenLaserSwitch())
	{
		LogError(_T("打开激光测距仪失败"));
		return FALSE;
	}
	
	Sleep(500);  // 等待激光稳定
	
	// 2. 读取当前距离
	float fCurrentDist = GetLaserDistance();
	if (fCurrentDist < 0)
	{
		LogError(_T("无法读取激光距离：激光测距仪读取失败，请检查硬件连接"));
		m_pIOController->CloseLaserSwitch();
		return FALSE;
	}
	
	LogInfo(_T("当前激光距离: %.2f mm"), fCurrentDist);
	
	// 3. 循环调整，直到达到目标范围
	const float TARGET = m_params.fTargetHeight;        // 100mm
	const float TOLERANCE = m_params.fCoarseTolerance;  // ±2mm
	
	int nMaxTries = 20;
	int nTryCount = 0;
	int nReadFailCount = 0;  // 读取失败计数
	
	while (nTryCount++ < nMaxTries)
	{
		// 检查停止请求
		if (m_bStopRequest)
		{
			LogWarning(_T("收到停止请求"));
			m_pIOController->CloseLaserSwitch();
			return FALSE;
		}
		
		fCurrentDist = GetLaserDistance();
		
		// 检查读取是否成功
		if (fCurrentDist < 0)
		{
			LogError(_T("第%d次调整 - 读取激光距离失败"), nTryCount);
			
			// 连续失败3次则中止
			if (++nReadFailCount >= 3)
			{
				LogError(_T("连续3次读取失败，粗调中止"));
				m_pIOController->CloseLaserSwitch();
				return FALSE;
			}
			
			Sleep(200);  // 等待后重试
			continue;
		}
		
		// 读取成功，重置失败计数
		nReadFailCount = 0;
		
		float fError = fCurrentDist - TARGET;
		
		LogInfo(_T("第%d次调整 - 距离: %.2f mm, 误差: %.2f mm"), 
			nTryCount, fCurrentDist, fError);
		
		// 达到目标范围
		if (fabs(fError) <= TOLERANCE)
		{
			LogInfo(_T("粗调完成！距离: %.2f mm (目标: %.2f ±%.2f mm)"), 
				fCurrentDist, TARGET, TOLERANCE);
			return TRUE;  // 保持激光打开，供后续步骤使用
		}
		
		// 计算移动量（Z轴）
		float fMoveZ = -fError * 0.8f;  // 80%补偿，避免过调
		
		// 限制单次移动量（安全考虑）
		if (fabs(fMoveZ) > 5.0f)
		{
			fMoveZ = (fMoveZ > 0) ? 5.0f : -5.0f;
		}
		
		// 移动机械臂
		RobotArmPosition pos = m_pRobotArm->GetCurrentPosition();
		pos.Z += fMoveZ;
		
		if (!m_pRobotArm->MoveTo(pos, 30))  // 30%慢速移动
		{
			LogError(_T("机械臂移动失败"));
			m_pIOController->CloseLaserSwitch();
			return FALSE;
		}
		
		Sleep(500);  // 等待稳定
	}
	
	LogError(_T("粗调失败：超过最大尝试次数(%d次)"), nMaxTries);
	m_pIOController->CloseLaserSwitch();
	return FALSE;
}

BOOL CProcedureController::ExecuteStep3_DetectPuncturePoint()
{
	LogInfo(_T("开始步骤3：识别穿刺点"));
	
	// 1. 关闭激光测距仪，避免干扰视觉识别
	if (m_pIOController && m_pIOController->IsInitialized())
	{
		LogInfo(_T("关闭激光测距仪..."));
		m_pIOController->CloseLaserSwitch();
		Sleep(200);
	}
	
	// 2. 视觉识别穿刺点
	if (!m_pVision || !m_pVision->IsConnected())
	{
		// 未启用视觉 → 使用当前位置作为穿刺点
		LogWarning(_T("视觉系统未启用，使用当前位置作为穿刺点"));
		
		if (m_pRobotArm && m_pRobotArm->IsConnected())
		{
			m_puncturePoint = m_pRobotArm->GetCurrentPosition();
			LogInfo(_T("穿刺点设为当前位置: (%.2f, %.2f, %.2f, Theta=%.2f°)"), 
				m_puncturePoint.X, m_puncturePoint.Y, m_puncturePoint.Z, m_puncturePoint.Theta);
			return TRUE;
		}
		else
		{
			LogError(_T("无法获取当前位置"));
			return FALSE;
		}
	}
	
	// 3. 识别穿刺点
	float camX, camY, camZ;
	LogInfo(_T("开始识别穿刺点..."));
	
	if (!m_pVision->DetectPuncturePoint(camX, camY, camZ))
	{
		LogError(_T("识别穿刺点失败"));
		return FALSE;
	}
	
	LogInfo(_T("穿刺点识别成功 - 相机坐标: (%.2f, %.2f, %.2f) mm"), camX, camY, camZ);
	
	// 4. 坐标转换并记录
	float robotX, robotY, robotZ;
	m_pVision->TransformCoordinate(camX, camY, camZ, 
	                               robotX, robotY, robotZ);
	
	m_puncturePoint.X = robotX;
	m_puncturePoint.Y = robotY;
	m_puncturePoint.Z = robotZ;
	
	// 5. ★ 计算目标姿态角度（针对穿刺点）
	// 根据视觉识别结果计算最佳穿刺角度
	// 视觉系统会提供角度信息，如不支持则返回默认0度
	m_puncturePoint.Theta = m_pVision->GetPunctureAngle(camX, camY, camZ);
	
	if (m_puncturePoint.Theta != 0.0f)
	{
		LogInfo(_T("视觉系统提供穿刺角度: %.2f°"), m_puncturePoint.Theta);
	}
	else
	{
		LogInfo(_T("使用默认垂直穿刺角度: 0.0°"));
	}
	
	LogInfo(_T("穿刺点坐标: (%.2f, %.2f, %.2f) mm, 姿态角度: %.2f°"), 
		robotX, robotY, robotZ, m_puncturePoint.Theta);
	
	// 6. ★ 新增：立即调整机械臂姿态到穿刺角度（旋转）
	if (!m_pRobotArm || !m_pRobotArm->IsConnected())
	{
		LogError(_T("机械臂未连接"));
		return FALSE;
	}
	
	LogInfo(_T("调整机械臂姿态到穿刺角度..."));
	
	// 获取当前位置
	RobotArmPosition currentPos = m_pRobotArm->GetCurrentPosition();
	
	// 只改变Theta（旋转），保持X/Y/Z不变（避免碰撞）
	RobotArmPosition thetaPos = currentPos;
	thetaPos.Theta = m_puncturePoint.Theta;
	
	if (!m_pRobotArm->MoveTo(thetaPos, 20))  // 20%较慢速度调整姿态
	{
		LogError(_T("姿态调整失败"));
		return FALSE;
	}
	
	// 等待姿态调整稳定
	Sleep(500);
	
	LogInfo(_T("步骤3完成 - 姿态已调整到穿刺角度: %.2f°"), m_puncturePoint.Theta);
	
	return TRUE;
}

BOOL CProcedureController::ExecuteStep4_PreciseAlignment()
{
	LogInfo(_T("开始步骤4：精准对位"));
	
	// 1. 打开激光测距仪
	if (!m_pIOController || !m_pIOController->IsInitialized())
	{
		LogError(_T("I/O控制器未初始化"));
		return FALSE;
	}
	
	LogInfo(_T("打开激光测距仪..."));
	if (!m_pIOController->OpenLaserSwitch())
	{
		LogError(_T("打开激光测距仪失败"));
		return FALSE;
	}
	
	Sleep(500);  // 等待激光稳定
	
	// 2. ★ 移动到穿刺点上方（安全高度 + 保持姿态）
	// 注意：姿态已经在步骤3中调整好了，这里直接移动到穿刺点上方
	if (!m_pRobotArm || !m_pRobotArm->IsConnected())
	{
		SetLastError(PROC_ERR_ROBOT_NOT_CONNECTED, _T("机械臂未连接"));
		LogError(_T("机械臂未连接"));
		m_pIOController->CloseLaserSwitch();
		return FALSE;
	}
	
	RobotArmPosition targetPos = m_puncturePoint;
	targetPos.Z += m_params.fSafeHeight;  // 加上安全高度
	// targetPos.Theta 已经在步骤3中设置好了
	
	LogInfo(_T("步骤4.1 - 移动到穿刺点上方: (%.2f, %.2f, %.2f) mm, 姿态: %.2f°"), 
		targetPos.X, targetPos.Y, targetPos.Z, targetPos.Theta);
	
	if (!m_pRobotArm->MoveTo(targetPos, 30))
	{
		SetLastError(PROC_ERR_ROBOT_MOVE_FAILED, _T("机械臂移动失败"));
		LogError(_T("机械臂移动失败"));
		m_pIOController->CloseLaserSwitch();
		return FALSE;
	}
	
	Sleep(500);

	// 2.5 XY闭环（IR像素闭环，先对齐再做Z精调）
	if (m_params.bEnableXYAlign)
	{
		LogInfo(_T("步骤4.XY - 启用XY闭环：开始IR像素对位"));
		if (!ExecuteStep4_XYAlign())
		{
			LogError(_T("步骤4.XY - XY闭环失败"));
			m_pIOController->CloseLaserSwitch();
			return FALSE;
		}
		LogInfo(_T("步骤4.XY - XY闭环完成"));
	}
	else
	{
		LogInfo(_T("步骤4.XY - XY闭环未启用，跳过"));
	}
	
	// 3. 精确调整高度（±0.2mm），使激光点与穿刺点重合
	const float FINE_TOLERANCE = m_params.fFineTolerance;  // 0.2mm
	const float TARGET = m_params.fTargetHeight;
	
	int nMaxTries = m_params.nMaxAdjustCount;  // 默认50次
	int nTryCount = 0;
	int nReadFailCount = 0;  // 读取失败计数
	
	LogInfo(_T("步骤4.2 - 开始精准对位（目标精度: ±%.2f mm）..."), FINE_TOLERANCE);
	LogInfo(_T("调整激光点与穿刺点重合..."));
	
	while (nTryCount++ < nMaxTries)
	{
		// 检查停止请求
		if (m_bStopRequest)
		{
			LogWarning(_T("收到停止请求"));
			m_pIOController->CloseLaserSwitch();
			return FALSE;
		}
		
		
		float fCurrentDist = GetLaserDistance();
		
		// 检查读取是否成功
		if (fCurrentDist < 0)
		{
			LogError(_T("第%d次微调 - 读取激光距离失败"), nTryCount);
			
			// 连续失败5次则中止
			if (++nReadFailCount >= 5)
			{
				LogError(_T("连续5次读取失败，精准对位中止"));
				m_pIOController->CloseLaserSwitch();
				return FALSE;
			}
			
			Sleep(200);
			continue;
		}
		
		// 读取成功，重置失败计数
		nReadFailCount = 0;
		
		float fError = fCurrentDist - TARGET;
		
		if (nTryCount % 5 == 0)  // 每5次输出一次日志
		{
			LogInfo(_T("第%d次微调 - 距离: %.3f mm, 误差: %.3f mm"), 
				nTryCount, fCurrentDist, fError);
		}
		
		// 达到精准范围（激光点与穿刺点重合）
		if (fabs(fError) <= FINE_TOLERANCE)
		{
			LogInfo(_T("精准对位完成！"));
			LogInfo(_T("  最终距离: %.3f mm (目标: %.2f ±%.2f mm)"), 
				fCurrentDist, TARGET, FINE_TOLERANCE);
			LogInfo(_T("  激光点与穿刺点重合"));
			m_pIOController->CloseLaserSwitch();
			return TRUE;
		}
		
		// 微调Z轴（小幅度）
		float fMoveZ = -fError * 0.5f;  // 50%修正
		
		// 确保最小步长
		if (fabs(fMoveZ) < 0.1f)
		{
			fMoveZ = (fError > 0) ? -0.1f : 0.1f;
		}
		
		// 限制最大步长
		if (fabs(fMoveZ) > 1.0f)
		{
			fMoveZ = (fMoveZ > 0) ? 1.0f : -1.0f;
		}
		
		// 移动机械臂（保持姿态不变）
		RobotArmPosition pos = m_pRobotArm->GetCurrentPosition();
		EnterCriticalSection(&m_cs);
		m_bLastRobotPosValid = TRUE;
		m_lastRobotPos = pos;
		LeaveCriticalSection(&m_cs);
		pos.Z += fMoveZ;
		// pos.Theta 保持不变！
		
		if (!m_pRobotArm->MoveTo(pos, 10))  // 10%极慢速移动
		{
			LogError(_T("机械臂微调失败"));
			m_pIOController->CloseLaserSwitch();
			return FALSE;
		}
		
		Sleep(300);  // 等待稳定
	}
	
	LogError(_T("精准对位失败，超过最大调整次数(%d次)"), nMaxTries);
	m_pIOController->CloseLaserSwitch();
	return FALSE;
}

BOOL CProcedureController::ExecuteStep4_XYAlign()
{
	if (!m_pVision || !m_pVision->IsConnected())
	{
		SetLastError(PROC_ERR_VISION_NOT_CONNECTED, _T("XY闭环需要视觉系统，但当前未连接"));
		LogError(_T("XY闭环需要视觉系统，但当前未连接"));
		return FALSE;
	}

	const int THRESH_PX = m_params.nXYPixelThreshold;
	const int MAX_ITERS = m_params.nXYMaxIters;
	const float MM_PER_PX_X = m_params.fMmPerPixelX;
	const float MM_PER_PX_Y = m_params.fMmPerPixelY;
	const float MAX_STEP = m_params.fXYMaxStepMm;
	const float MIN_STEP = m_params.fXYMinStepMm;
	const int DETECT_RETRIES = 3;

	for (int iter = 1; iter <= MAX_ITERS; ++iter)
	{
		if (m_bStopRequest)
		{
			SetLastError(PROC_ERR_STOP_REQUESTED, _T("收到停止请求"));
			LogWarning(_T("XY闭环收到停止请求"));
			return FALSE;
		}

		int uLaser = 0, vLaser = 0;
		int uTarget = 0, vTarget = 0;
		BOOL bLaserOk = FALSE;
		BOOL bTargetOk = FALSE;
		for (int r = 0; r < DETECT_RETRIES; ++r)
		{
			bLaserOk = m_pVision->DetectLaserSpotPixelIR(uLaser, vLaser);
			bTargetOk = m_pVision->DetectPuncturePointPixelIR(uTarget, vTarget);
			if (bLaserOk && bTargetOk)
			{
				break;
			}
			Sleep(20);
		}
		if (!bLaserOk)
		{
			SetLastError(PROC_ERR_VISION_DETECT_FAILED, _T("未检测到IR激光光斑"));
			LogError(_T("XY闭环第%d次：未检测到IR激光光斑（重试%d次）"), iter, DETECT_RETRIES);
			return FALSE;
		}
		if (!bTargetOk)
		{
			SetLastError(PROC_ERR_VISION_DETECT_FAILED, _T("未检测到IR穿刺点"));
			LogError(_T("XY闭环第%d次：未检测到IR穿刺点（重试%d次）"), iter, DETECT_RETRIES);
			return FALSE;
		}

		const int dxPx = uLaser - uTarget;
		const int dyPx = vLaser - vTarget;
		EnterCriticalSection(&m_cs);
		m_lastDxPx = dxPx;
		m_lastDyPx = dyPx;
		LeaveCriticalSection(&m_cs);

		if (abs(dxPx) <= THRESH_PX && abs(dyPx) <= THRESH_PX)
		{
			EnterCriticalSection(&m_cs);
			m_lastDxMm = 0.0f;
			m_lastDyMm = 0.0f;
			LeaveCriticalSection(&m_cs);
			LogInfo(_T("XY闭环收敛：dx=%dpx dy=%dpx 阈值=%dpx"), dxPx, dyPx, THRESH_PX);
			return TRUE;
		}

		float dXmm = -(float)dxPx * MM_PER_PX_X;
		float dYmm = -(float)dyPx * MM_PER_PX_Y;

		// 限幅
		if (dXmm > MAX_STEP) dXmm = MAX_STEP;
		if (dXmm < -MAX_STEP) dXmm = -MAX_STEP;
		if (dYmm > MAX_STEP) dYmm = MAX_STEP;
		if (dYmm < -MAX_STEP) dYmm = -MAX_STEP;

		// 最小步长（防止进入死区不动）
		if (abs(dxPx) > THRESH_PX && fabs(dXmm) < MIN_STEP) dXmm = (dXmm >= 0.0f) ? MIN_STEP : -MIN_STEP;
		if (abs(dyPx) > THRESH_PX && fabs(dYmm) < MIN_STEP) dYmm = (dYmm >= 0.0f) ? MIN_STEP : -MIN_STEP;

		EnterCriticalSection(&m_cs);
		m_lastDxMm = dXmm;
		m_lastDyMm = dYmm;
		LeaveCriticalSection(&m_cs);

		RobotArmPosition pos = m_pRobotArm->GetCurrentPosition();
		EnterCriticalSection(&m_cs);
		m_bLastRobotPosValid = TRUE;
		m_lastRobotPos = pos;
		LeaveCriticalSection(&m_cs);
		pos.X += dXmm;
		pos.Y += dYmm;

		if (iter % 5 == 0)
		{
			LogInfo(_T("XY闭环第%d次：dx=%dpx dy=%dpx -> dX=%.3fmm dY=%.3fmm"), iter, dxPx, dyPx, dXmm, dYmm);
		}

		if (!m_pRobotArm->MoveTo(pos, 10))
		{
			SetLastError(PROC_ERR_ROBOT_MOVE_FAILED, _T("机械臂MoveTo失败"));
			LogError(_T("XY闭环第%d次：机械臂MoveTo失败"), iter);
			return FALSE;
		}

		Sleep(120);
	}

	LogError(_T("XY闭环未收敛：超过最大迭代次数%d"), MAX_ITERS);
	SetLastError(PROC_ERR_TIMEOUT, _T("XY闭环未收敛"));
	return FALSE;
}

BOOL CProcedureController::ExecuteStep5_Disinfection()
{
	LogInfo(_T("【步骤5】消毒准备"));
	
	// 1. 确保激光测距仪已关闭
	if (m_pIOController && m_pIOController->IsInitialized())
	{
		m_pIOController->CloseLaserSwitch();
	}
	
	// 2. 打开消毒液阀门
	if (!m_pIOController || !m_pIOController->IsInitialized())
	{
		LogError(_T("I/O控制器未初始化"));
		return FALSE;
	}
	
	LogInfo(_T("打开消毒液阀门..."));
	if (!m_pIOController->OpenDisinfectSwitch())
	{
		LogError(_T("打开消毒液阀门失败"));
		return FALSE;
	}
	
	// 3. 等待指定时间
	float fWaitTime = m_params.fDisinfectTime;  // 默认2秒
	LogInfo(_T("消毒中，等待 %.1f 秒..."), fWaitTime);
	
	// 分段等待，以便响应停止请求
	int nWaitMs = (int)(fWaitTime * 1000);
	int nStepMs = 100;  // 每100ms检查一次
	
	for (int i = 0; i < nWaitMs; i += nStepMs)
	{
		if (m_bStopRequest)
		{
			LogWarning(_T("收到停止请求"));
			m_pIOController->CloseDisinfectSwitch();
			return FALSE;
		}
		
		Sleep(nStepMs);
	}
	
	// 4. 关闭消毒液阀门
	if (!m_pIOController->CloseDisinfectSwitch())
	{
		LogError(_T("关闭消毒液阀门失败"));
		return FALSE;
	}
	
	LogInfo(_T("【步骤5】完成 - 消毒完成"));
	return TRUE;
}

BOOL CProcedureController::ExecuteStep6_Puncture()
{
	LogInfo(_T("开始步骤6：穿刺执行"));
	
	// 1. 检查232串口
	if (!m_pSerial232 || !m_pSerial232->IsOpen())
	{
		LogError(_T("232串口未打开"));
		return FALSE;
	}
	
	// 2. 获取穿刺深度（单位：mm或单位，取决于接口的配置）
	float fDepth = m_params.fPunctureDepth;  // 例如：1000单位（或者 50个mm）
	
	// 3. 构造穿刺指令格式：MR-深度
	// 例如：深度为1000，发送 "MR-1000\r\n"
	// MR 表示向前运动，-1000 表示前进1000个单位
	CString strCmd;
	strCmd.Format(_T("MR-%.0f\r\n"), fDepth);
	
	CStringA strCmdA(strCmd);
	
	LogInfo(_T("发送穿刺指令：MR-%.0f (深度 %.0f 单位)"), fDepth, fDepth);
	
	// 4. 发送穿刺指令
	if (!m_pSerial232->SendData(strCmdA.GetString(), strCmdA.GetLength(), FALSE))
	{
		LogError(_T("发送穿刺指令失败"));
		return FALSE;
	}
	
	LogInfo(_T("穿刺执行中，等待完成..."));
	
	// 5. ★ 动态计算超时时间
	// 假设每100单位需要0.5秒，基础超时1秒
	int nTimeout = (int)(fDepth / 100.0f * 500.0f) + 1000;
	
	// 最小超时2秒，最大超时30秒
	if (nTimeout < 2000) nTimeout = 2000;
	if (nTimeout > 30000) nTimeout = 30000;
	
	LogInfo(_T("穿刺超时设置: %d 毫秒 (深度: %.0f)"), nTimeout, fDepth);
	
	BOOL bCompleted = WaitForMotorComplete(nTimeout);

	// WaitForMotorComplete() 当前策略为“等待指定时间”，仅在收到停止请求时返回FALSE
	if (!bCompleted)
	{
		LogWarning(_T("穿刺步骤被中止（收到停止请求）"));
		return FALSE;
	}
	
	LogInfo(_T("步骤6完成 - 穿刺成功"));
	return TRUE;
}

BOOL CProcedureController::ExecuteStep7_Infusion()
{
	LogInfo(_T("【步骤7】输液启动"));
	
	// 1. 打开输液阀门
	if (!m_pIOController || !m_pIOController->IsInitialized())
	{
		LogError(_T("I/O控制器未初始化"));
		return FALSE;
	}
	
	LogInfo(_T("打开输液阀门..."));
	if (!m_pIOController->OpenInfusionSwitch())
	{
		LogError(_T("打开输液阀门失败"));
		return FALSE;
	}
	
	LogInfo(_T("输液阀门已打开"));
	
	// 2. 持续监控输液传感器（PIN 2）
	// 这是一个持久状态，由定时器监控，此处仅启动
	// 在实际应用中，可以通过定时器定期检查传感器状态
	
	// 3. 流程结束提示
	LogInfo(_T("========== 流程执行完成 =========="));
	LogInfo(_T("注意：输液阀门保持打开状态，请监控输液传感器"));
	
