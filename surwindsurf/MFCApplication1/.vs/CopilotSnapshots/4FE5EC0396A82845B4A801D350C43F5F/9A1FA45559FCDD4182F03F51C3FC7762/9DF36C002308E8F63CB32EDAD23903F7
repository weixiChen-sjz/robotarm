#pragma once
#include <Windows.h>

// I/O 通道类型
enum IOChannelType
{
    IO_TYPE_INPUT = 0,
    IO_TYPE_OUTPUT
};

// I/O 通道状态
enum IOChannelState
{
    IO_STATE_LOW = 0,
    IO_STATE_HIGH = 1,
    IO_STATE_UNKNOWN = -1
};

// I/O 通道信息
struct IOChannelInfo
{
    int nChannelId;           // 通道ID
    IOChannelType type;       // 通道类型
    IOChannelState state;     // 当前状态
    CString strName;          // 通道名称
    
    IOChannelInfo() 
        : nChannelId(0)
        , type(IO_TYPE_INPUT)
        , state(IO_STATE_UNKNOWN)
        , strName(_T(""))
    {}
};

class CIOController
{
public:
    CIOController();
    ~CIOController();

    // 初始化 I/O 控制器
    BOOL Initialize();
    
    // 关闭 I/O 控制器
    void Shutdown();
    
    // 读取输入通道状态
    IOChannelState ReadInput(int nChannelId);
    
    // 设置输出通道状态
    BOOL WriteOutput(int nChannelId, IOChannelState state);
    
    // 获取通道信息
    BOOL GetChannelInfo(int nChannelId, IOChannelInfo& info);
    
    // 设置通道信息
    void SetChannelInfo(int nChannelId, const IOChannelInfo& info);
    
    // 刷新所有输入通道状态
    void RefreshInputs();
    
    // 检查是否已初始化
    BOOL IsInitialized() const { return m_bInitialized; }

private:
    BOOL m_bInitialized;              // 是否已初始化
    IOChannelInfo m_channels[4];      // 4个通道（2输入+2输出）
    
    // 模拟硬件读取
    IOChannelState SimulateReadHardware(int nChannelId);
    
    // 模拟硬件写入
    BOOL SimulateWriteHardware(int nChannelId, IOChannelState state);
};
