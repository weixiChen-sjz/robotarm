// EVOC GPIO硬件控制DLL接口
// 研华GPIO控制卡驱动接口定义
#pragma once

#ifdef __cplusplus
extern "C" {
#endif

// 返回状态定义
#define BPI_STATUS_SUCCESSFUL    0    // 成功
#define BPI_STATUS_FAILED       -1    // 失败

// GPIO引脚定义
// 输入引脚：1-4（对应通道0-3的低4位）
// 输出引脚：5-8（对应通道0-3的高4位）

/**
 * @brief 初始化BPI设备
 * @return BPI_STATUS_SUCCESSFUL 成功, BPI_STATUS_FAILED 失败
 */
int __stdcall BPI_Init(void);

/**
 * @brief 初始化GPIO功能
 * @param num 返回GPIO设备数量
 * @return BPI_STATUS_SUCCESSFUL 成功, BPI_STATUS_FAILED 失败
 */
int __stdcall BPI_GPIO_Init(unsigned char* num);

/**
 * @brief 设置GPIO引脚模式（输入/输出）
 * @param setIO 模式设置字节，每位对应一个引脚（0=输入，1=输出）
 *              示例：0x0F = 0b00001111 表示低4位为输入，高4位为输出
 * @param reserved 保留参数，设置为1
 * @return BPI_STATUS_SUCCESSFUL 成功, BPI_STATUS_FAILED 失败
 */
int __stdcall BPI_GPIO_SetIoMode(BYTE* setIO, int reserved);

/**
 * @brief 设置GPIO输出电平
 * @param setIO 输出电平字节，每位对应一个引脚（0=低电平，1=高电平）
 * @param reserved 保留参数，设置为1
 * @return BPI_STATUS_SUCCESSFUL 成功, BPI_STATUS_FAILED 失败
 */
int __stdcall BPI_GPIO_SetLevels(BYTE* setIO, int reserved);

/**
 * @brief 读取GPIO输入电平
 * @param levels 返回输入电平字节，每位对应一个引脚（0=低电平，1=高电平）
 * @param reserved 保留参数，设置为1
 * @return BPI_STATUS_SUCCESSFUL 成功, BPI_STATUS_FAILED 失败
 */
int __stdcall BPI_GPIO_GetLevels(BYTE* levels, int reserved);

/**
 * @brief 设置单个GPIO引脚电平
 * @param pin 引脚号（1-8）
 *            1-4: 输入引脚（只能读取）
 *            5-8: 输出引脚（可以设置）
 * @param level 电平值（0=低电平，1=高电平）
 * @return BPI_STATUS_SUCCESSFUL 成功, BPI_STATUS_FAILED 失败
 */
int __stdcall BPI_GPIO_SetPinLevel(int pin, int level);

/**
 * @brief 关闭GPIO设备
 * @return BPI_STATUS_SUCCESSFUL 成功, BPI_STATUS_FAILED 失败
 */
int __stdcall BPI_GPIO_Close(void);

/**
 * @brief 关闭BPI设备
 * @return BPI_STATUS_SUCCESSFUL 成功, BPI_STATUS_FAILED 失败
 */
int __stdcall BPI_Close(void);

#ifdef __cplusplus
}
#endif

// GPIO引脚映射说明
// =====================================================
// 物理引脚 | 逻辑位 | 功能        | 设备映射
// =====================================================
// PIN 1    | bit 0  | 输入1       | 输液传感器
// PIN 2    | bit 1  | 输入2       | 消毒液传感器
// PIN 3    | bit 2  | 输入3       | 保留
// PIN 4    | bit 3  | 输入4       | 保留
// PIN 5    | bit 4  | 输出1       | 输液开关
// PIN 6    | bit 5  | 输出2       | 消毒液开关
// PIN 7    | bit 6  | 输出3       | 保留
// PIN 8    | bit 7  | 输出4       | 保留
// =====================================================

