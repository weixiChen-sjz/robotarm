#include "pch.h"
#include "IOController.h"

CIOController::CIOController()
    : m_bInitialized(FALSE)
    , m_hwState(IO_HW_DISCONNECTED)
{
    // 初始化通道信息
    for (int i = 0; i < 4; i++)
    {
        m_channels[i].nChannelId = i;
        m_channels[i].state = IO_STATE_UNKNOWN;
        
        if (i < 2)
        {
            m_channels[i].type = IO_TYPE_INPUT;
            if (i == IO_DEVICE_INFUSION_INPUT)
            {
                m_channels[i].strName.Format(_T("输入%d"), i + 1);
                m_channels[i].strDeviceName = _T("输液传感器");
            }
            else if (i == IO_DEVICE_DISINFECT_INPUT)
            {
                m_channels[i].strName.Format(_T("输入%d"), i + 1);
                m_channels[i].strDeviceName = _T("消毒液传感器");
            }
        }
        else
        {
            m_channels[i].type = IO_TYPE_OUTPUT;
            if (i == IO_DEVICE_INFUSION_OUTPUT)
            {
                m_channels[i].strName.Format(_T("输出%d"), i - 1);
                m_channels[i].strDeviceName = _T("输液开关");
            }
            else if (i == IO_DEVICE_DISINFECT_OUTPUT)
            {
                m_channels[i].strName.Format(_T("输出%d"), i - 1);
                m_channels[i].strDeviceName = _T("消毒液开关");
            }
        }
    }
}

CIOController::~CIOController()
{
    Shutdown();
}

BOOL CIOController::Initialize()
{
    if (m_bInitialized)
    {
        return TRUE;
    }

    // 检测硬件连接
    if (!DetectHardware())
    {
        m_hwState = IO_HW_DISCONNECTED;
        return FALSE;  // 未检测到硬件，初始化失败
    }
    
    m_hwState = IO_HW_CONNECTED;
    
    // 初始化输入通道状态 - 从硬件读取初始状态
    for (int i = 0; i < 2; i++)
    {
        // 确保初始化时状态为LOW，避免随机高电平
        m_channels[i].state = IO_STATE_LOW;
        // 从硬件读取真实状态（如果有实际硬件）
        IOChannelState hwState = SimulateReadHardware(i);
        if (hwState != IO_STATE_UNKNOWN)
        {
            m_channels[i].state = hwState;
        }
    }
    
    // 初始化输出通道状态 - 设置为安全的低电平（关闭状态）
    for (int i = 2; i < 4; i++)
    {
        m_channels[i].state = IO_STATE_LOW;
        SimulateWriteHardware(i, IO_STATE_LOW);
    }

    m_bInitialized = TRUE;
    return TRUE;
}

void CIOController::Shutdown()
{
    if (!m_bInitialized)
    {
        return;
    }

    // 关闭所有输出（安全措施）
    for (int i = 2; i < 4; i++)
    {
        WriteOutput(i, IO_STATE_LOW);
    }

    m_bInitialized = FALSE;
    m_hwState = IO_HW_DISCONNECTED;
}

IOChannelState CIOController::ReadInput(int nChannelId)
{
    if (!m_bInitialized || nChannelId < 0 || nChannelId >= 2)
    {
        return IO_STATE_UNKNOWN;
    }
    
    // 检查硬件连接
    if (!IsHardwareConnected())
    {
        return IO_STATE_UNKNOWN;
    }

    // 从硬件读取状态
    IOChannelState hwState = SimulateReadHardware(nChannelId);
    if (hwState != IO_STATE_UNKNOWN)
    {
        m_channels[nChannelId].state = hwState;
    }
    return m_channels[nChannelId].state;
}

BOOL CIOController::WriteOutput(int nChannelId, IOChannelState state)
{
    if (!m_bInitialized || nChannelId < 2 || nChannelId >= 4)
    {
        return FALSE;
    }
    
    // 检查硬件连接 - 关键安全检查！
    if (!IsHardwareConnected())
    {
        // 未连接硬件时不允许控制输出
        return FALSE;
    }

    // 写入硬件
    if (SimulateWriteHardware(nChannelId, state))
    {
        m_channels[nChannelId].state = state;
        return TRUE;
    }

    return FALSE;
}

BOOL CIOController::GetChannelInfo(int nChannelId, IOChannelInfo& info)
{
    if (nChannelId < 0 || nChannelId >= 4)
    {
        return FALSE;
    }

    info = m_channels[nChannelId];
    return TRUE;
}

void CIOController::SetChannelInfo(int nChannelId, const IOChannelInfo& info)
{
    if (nChannelId >= 0 && nChannelId < 4)
    {
        m_channels[nChannelId] = info;
    }
}

void CIOController::RefreshInputs()
{
    if (!m_bInitialized)
    {
        return;
    }

    for (int i = 0; i < 2; i++)
    {
        ReadInput(i);
    }
}

CString CIOController::GetHardwareStateText() const
{
    switch (m_hwState)
    {
    case IO_HW_CONNECTED:
        return _T("已连接");
    case IO_HW_DISCONNECTED:
        return _T("未连接");
    case IO_HW_ERROR:
        return _T("连接错误");
    default:
        return _T("未知");
    }
}

void CIOController::SimulateInputChange(int nChannelId, IOChannelState newState)
{
    // 仅用于测试：手动模拟输入状态变化
    // 实际硬件应用中不需要此方法，输入状态由硬件决定
    if (nChannelId >= 0 && nChannelId < 2)
    {
        m_channels[nChannelId].state = newState;
    }
}

// 业务层封装方法
BOOL CIOController::OpenInfusionSwitch()
{
    return WriteOutput(IO_DEVICE_INFUSION_OUTPUT, IO_STATE_HIGH);
}

BOOL CIOController::CloseInfusionSwitch()
{
    return WriteOutput(IO_DEVICE_INFUSION_OUTPUT, IO_STATE_LOW);
}

BOOL CIOController::OpenDisinfectSwitch()
{
    return WriteOutput(IO_DEVICE_DISINFECT_OUTPUT, IO_STATE_HIGH);
}

BOOL CIOController::CloseDisinfectSwitch()
{
    return WriteOutput(IO_DEVICE_DISINFECT_OUTPUT, IO_STATE_LOW);
}

BOOL CIOController::GetInfusionSensorState()
{
    IOChannelState state = ReadInput(IO_DEVICE_INFUSION_INPUT);
    return (state == IO_STATE_HIGH);
}

BOOL CIOController::GetDisinfectSensorState()
{
    IOChannelState state = ReadInput(IO_DEVICE_DISINFECT_INPUT);
    return (state == IO_STATE_HIGH);
}

